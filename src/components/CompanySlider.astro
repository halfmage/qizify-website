---
import { Icon } from 'astro-icon/components';

interface Point {
	text: string;
	highlight: string;
}

interface Tab {
	tabLabel: string;
	audience: string;
	image: string;
	points: Point[];
	note: string;
}

interface Props {
	headline: string;
	tabs: Tab[];
}

const { headline, tabs } = Astro.props;
---

<section class="py-20 md:py-32 px-6 md:px-8" id="made-for-company">
	<div class="max-w-container mx-auto">
		<div class="text-center mb-12 md:mb-16">
			<span class="section-label mb-4 block">Use Cases</span>
			<h2 class="text-heading md:text-display-sm text-white m-0 max-w-[800px] mx-auto">
				{headline}
			</h2>
		</div>

		<!-- Tab Navigation -->
		<div class="flex justify-center mb-10 md:mb-14">
			<div class="inline-flex gap-1 p-1 bg-surface rounded-lg border border-border">
				{tabs.map((tab, index) => (
					<button
						class={`company-tab px-5 py-2 rounded-md text-sm font-medium transition-all duration-200 ${index === 0 ? 'bg-primary/15 text-primary' : 'text-muted hover:text-white'}`}
						data-tab-index={index}
					>
						{tab.tabLabel}
					</button>
				))}
			</div>
		</div>

		<!-- Tab Content -->
		<div class="max-w-5xl mx-auto">
			{tabs.map((tab, index) => (
				<div
					class={`company-tab-content ${index === 0 ? 'block' : 'hidden'}`}
					data-content-index={index}
				>
					<div class="bg-surface border border-border rounded-xl overflow-hidden flex flex-col lg:flex-row">
						<!-- Content -->
						<div class="flex-1 p-8 md:p-10 flex flex-col gap-6">
							<h3 class="text-heading-sm text-white m-0">{tab.audience}</h3>

							<ul class="list-none m-0 p-0 flex flex-col gap-4 flex-1">
								{tab.points.map((point) => {
									const highlightIndex = point.text.indexOf(point.highlight);
									const beforeHighlight = highlightIndex >= 0 ? point.text.substring(0, highlightIndex) : '';
									const afterHighlight = highlightIndex >= 0 ? point.text.substring(highlightIndex + point.highlight.length) : point.text;

									return (
										<li class="flex items-start gap-3">
											<span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0"></span>
											<p class="text-sm leading-relaxed text-white/80 m-0">
												{beforeHighlight && <span>{beforeHighlight}</span>}
												<span class="text-white font-medium">{point.highlight}</span>
												{afterHighlight && <span>{afterHighlight}</span>}
											</p>
										</li>
									);
								})}
							</ul>

							<!-- Note -->
							<div class="bg-primary/5 border border-primary/10 rounded-lg px-5 py-4 flex items-start gap-3">
								<Icon name="hugeicons:sparkles" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
								<p class="text-sm text-muted leading-relaxed m-0">
									{tab.note}
								</p>
							</div>
						</div>

						<!-- Image -->
						<div class="relative w-full lg:w-[42%] h-48 sm:h-64 lg:h-auto lg:min-h-[400px] shrink-0 order-first lg:order-last">
							<img
								src={tab.image}
								alt={tab.audience}
								class="absolute inset-0 w-full h-full object-cover"
								loading="lazy"
							/>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	function initCompanyTabs() {
		const tabButtons = document.querySelectorAll('.company-tab');
		const tabContents = document.querySelectorAll('.company-tab-content');

		tabButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const index = button.getAttribute('data-tab-index');

				tabButtons.forEach((btn) => {
					btn.classList.remove('bg-primary/15', 'text-primary');
					btn.classList.add('text-muted', 'hover:text-white');
				});
				button.classList.add('bg-primary/15', 'text-primary');
				button.classList.remove('text-muted', 'hover:text-white');

				tabContents.forEach((content) => {
					const contentIndex = content.getAttribute('data-content-index');
					if (contentIndex === index) {
						content.classList.remove('hidden');
						content.classList.add('block');
					} else {
						content.classList.add('hidden');
						content.classList.remove('block');
					}
				});
			});
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initCompanyTabs);
	} else {
		initCompanyTabs();
	}
</script>

---
// Centered section header plus a contained list of horizontal data bars.
// Bar widths are scaled to the largest value in the set so the ranking reads
// clearly, while the literal value (e.g. "22%") stays as the label.
interface BarItem {
	value: string;
	label: string;
}

interface Props {
	label: string;
	headline: string;
	intro: string;
	items: BarItem[];
	color?: 'primary' | 'accent';
}

const { label, headline, intro, items = [], color = 'primary' } = Astro.props;

const max = Math.max(...items.map((i) => parseFloat(i.value) || 0), 1);
const valueClass = color === 'accent' ? 'text-accent' : 'text-primary';
const barClass = color === 'accent' ? 'bg-accent' : 'bg-primary';
---

<section class="py-12 md:py-16 px-6 md:px-8">
	<div class="max-w-2xl mx-auto">
		<div class="text-center mb-10">
			<span class="section-label mb-4 block">{label}</span>
			<h2 class="text-heading md:text-display-sm text-white m-0 mb-4">{headline}</h2>
			<p class="text-base text-muted leading-relaxed m-0 max-w-xl mx-auto">{intro}</p>
		</div>
		<div class="bg-surface border border-border rounded-xl p-6 md:p-8">
			<ul class="list-none m-0 p-0 space-y-5">
				{items.map((item) => (
					<li>
						<div class="flex items-baseline justify-between mb-2">
							<span class="text-sm text-white/80">{item.label}</span>
							<span class={`text-sm font-semibold font-mono ${valueClass}`}>{item.value}</span>
						</div>
						<div class="h-1.5 rounded-full bg-border overflow-hidden">
							<div class={`h-full rounded-full ${barClass}`} style={`width:${((parseFloat(item.value) || 0) / max) * 100}%`}></div>
						</div>
					</li>
				))}
			</ul>
		</div>
	</div>
</section>

---
import Button from './Button.astro';
import AppMockup from './AppMockup.astro';

interface Props {
	badge: string;
	headline: string;
	subheadline: string;
	ctaPrimary: string;
	ctaSecondary: string;
	currentLang: 'en' | 'de';
}

const { badge, headline, subheadline, ctaPrimary, ctaSecondary, currentLang } = Astro.props;

const headlineLines = headline.split('\n');
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-32 pb-16" id="hero">
	<!-- Subtle radial glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] opacity-30 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.15) 0%, transparent 70%);"></div>

	<div class="relative z-10 max-w-container mx-auto w-full px-6 md:px-8">
		<div class="max-w-6xl mx-auto text-center flex flex-col items-center gap-6">
			<!-- Section label -->
			<span class="section-label">{badge}</span>

			<!-- Headline -->
			<h1 class="text-display-sm md:text-display text-white m-0">
				{headlineLines.map((line, index) => (
					<>
						{line}
						{index < headlineLines.length - 1 && <br />}
					</>
				))}
			</h1>

			<!-- Subheadline -->
			<p class="text-lg leading-relaxed text-muted max-w-2xl m-0">
				{subheadline}
			</p>

			<!-- CTAs -->
			<div class="flex flex-col sm:flex-row gap-3 mt-4">
				<Button
					variant="primary"
					href="#demo-request"
					aria-label={ctaPrimary}
				>
					{ctaPrimary}
					<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</Button>
				<Button
					variant="secondary"
					href="#how-it-works"
					aria-label={ctaSecondary}
				>
					{ctaSecondary}
				</Button>
			</div>
		</div>

		<!-- App mockup with gradient fade -->
		<div class="mt-16 md:mt-24 relative p-4 md:p-12 rounded-3xl bg-gradient-to-b from-primary/5 to-primary/80 overflow-hidden">
			<div class="relative shadow-xl mockup-scale-wrapper">
				<AppMockup currentLang={currentLang} />
			</div>
		</div>
	</div>
</section>

<style>
	@media (max-width: 767px) {
		.mockup-scale-wrapper {
			width: 180%;
			transform: scale(0.555);
			transform-origin: top left;
			margin-bottom: -45%;
		}
	}
</style>

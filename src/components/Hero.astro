---
import Button from './Button.astro';
import AppMockup from './AppMockup.astro';

interface HeroStat {
	value: string;
	label: string;
}

interface Props {
	badge: string;
	headline: string;
	subheadline: string;
	ctaPrimary: string;
	ctaSecondary: string;
	stats?: HeroStat[];
	currentLang: 'en' | 'de';
}

const { badge, headline, subheadline, ctaPrimary, ctaSecondary, stats = [], currentLang } = Astro.props;

const headlineLines = headline.split('\n');
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-32 pb-16" id="hero">
	<!-- Aurora glow — dual radial blobs (violet + amber) for warmth and brand presence -->
	<div class="absolute inset-0 pointer-events-none glow-aurora" aria-hidden="true"></div>

	<div class="relative z-10 max-w-container mx-auto w-full px-6 md:px-8">
		<div class="max-w-6xl mx-auto text-center flex flex-col items-center gap-6">
			<!-- Award badge — strongest single trust signal for German B2B audience -->
			<a href={currentLang === 'de' ? '/de#why-choose-us' : '/#why-choose-us'} class="inline-flex items-center gap-1.5 text-xs font-medium text-accent bg-accent/10 border border-accent/30 rounded-full px-3 py-1 hover:bg-accent/15 transition-colors no-underline">
				<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 6.4L21 9l-5 4.6L17.6 21 12 17.3 6.4 21 8 13.6 3 9l6.6-.6L12 2z"/></svg>
				{currentLang === 'en' ? 'BMWE KI-Preis 2025 Winner' : 'BMWE KI-Preis 2025 Gewinner'}
			</a>

			<!-- Section label -->
			<span class="section-label">{badge}</span>

			<!-- Headline — gradient on the last line (the "conclusion" sentence) -->
			<h1 class="text-display-sm md:text-display text-white m-0">
				{headlineLines.map((line, index) => (
					<>
						{index === headlineLines.length - 1 && headlineLines.length > 1
							? <span class="gradient-text-primary">{line}</span>
							: line}
						{index < headlineLines.length - 1 && <br />}
					</>
				))}
			</h1>

			<!-- Subheadline — full white at text-xl for Ausbilder readability -->
			<p class="text-xl leading-relaxed text-white max-w-2xl m-0">
				{subheadline}
			</p>

			<!-- Trust line + compliance badges — above-fold social proof and category-leader signals -->
			<div class="flex flex-col items-center gap-2 mt-2">
				<p class="text-sm text-muted m-0">
					{currentLang === 'en' ? 'Trusted by 30+ German companies.' : 'Schon von 30+ deutschen Unternehmen genutzt.'}
				</p>
				<div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs text-muted">
					<span class="inline-flex items-center gap-1.5">
						<svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						{currentLang === 'en' ? 'GDPR-compliant' : 'DSGVO-konform'}
					</span>
					<span class="inline-flex items-center gap-1.5">
						<svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						{currentLang === 'en' ? 'German-hosted' : 'Server in Deutschland'}
					</span>
					<span class="inline-flex items-center gap-1.5">
						<svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						{currentLang === 'en' ? 'IHK-aligned' : 'IHK-konform'}
					</span>
				</div>
			</div>

			<!-- CTA group: primary, secondary, Calendly fallback, microcopy — wrapped in own flex-col to isolate from parent gap-6 -->
			<div class="flex flex-col items-center gap-2 mt-2">
				<div class="flex flex-col sm:flex-row gap-3">
					<Button
						variant="primary"
						href="#demo-request"
						aria-label={ctaPrimary}
					>
						{ctaPrimary}
						<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</Button>
					<Button
						variant="secondary"
						href={currentLang === 'de' ? '/de/ausbildungskosten-rechner' : '/apprenticeship-savings-calculator'}
						aria-label={ctaSecondary}
					>
						{ctaSecondary}
					</Button>
				</div>

				<a href="https://calendly.com/learnslice-team/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-muted hover:text-white transition-colors">
					{currentLang === 'en' ? 'Or pick a 30-min slot directly' : 'Oder direkt einen 30-Min-Termin wählen'}
					<svg class="w-3.5 h-3.5 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
				</a>

				<p class="text-xs text-muted m-0">
					{currentLang === 'en'
						? '30-min call · no pitch · reply within 1 business day'
						: '30-Min-Gespräch · kein Pitch · Antwort innerhalb von 1 Werktag'}
				</p>
			</div>

			<!-- Stat strip — proof points above-fold with amber numbers (focused home for accent color) -->
			{stats.length > 0 && (
				<ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 mt-4 text-base text-muted m-0 p-0 list-none">
					{stats.map((stat, index) => (
						<>
							<li class="flex items-baseline gap-1.5">
								<span class="text-accent font-semibold">{stat.value}</span>
								<span>{stat.label}</span>
							</li>
							{index < stats.length - 1 && <li class="text-border-light" aria-hidden="true">·</li>}
						</>
					))}
				</ul>
			)}
		</div>

		<!-- App mockup — softer gradient frame (was primary/5 → primary/80 which made bottom a violet wall) -->
		<div class="mt-16 md:mt-24 relative p-4 md:p-12 rounded-3xl bg-gradient-to-b from-primary/15 to-primary/45 ring-1 ring-primary/25 overflow-hidden">
			<div class="relative shadow-xl mockup-scale-wrapper">
				<AppMockup currentLang={currentLang} />
			</div>
		</div>
	</div>
</section>

<style>
	@media (max-width: 767px) {
		.mockup-scale-wrapper {
			width: 180%;
			transform: scale(0.555);
			transform-origin: top left;
			margin-bottom: -45%;
		}
	}
</style>

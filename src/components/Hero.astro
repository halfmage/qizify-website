---
import Button from './Button.astro';
import AppMockup from './AppMockup.astro';

interface HeroStat {
	value: string;
	label: string;
}

interface Props {
	headline: string;
	subheadline: string;
	ctaPrimary: string;
	ctaSecondary: string;
	stats?: HeroStat[];
	currentLang: 'en' | 'de';
}

const { headline, subheadline, ctaPrimary, ctaSecondary, stats = [], currentLang } = Astro.props;

const headlineLines = headline.split('\n');
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-32 pb-6" id="hero">
	<!-- Full-bleed hero photo — LCP element, preloaded in BaseLayout head -->
	<img
		src="/images/hero/hero-background.webp"
		alt=""
		role="presentation"
		class="absolute inset-0 w-full h-full object-cover object-[70%_center] z-0"
		loading="eager"
		fetchpriority="high"
		decoding="async"
		width="1920"
		height="1080"
	/>

	<!-- Localized scrim — dark on the left for text legibility, vivid on the right (the people), plus a bottom fade to page background for a seamless transition into the mockup -->
	<div class="absolute inset-0 z-[1] pointer-events-none bg-[linear-gradient(to_right,rgba(42,38,34,0.80),rgba(42,38,34,0.46)_45%,rgba(42,38,34,0.12)_78%),linear-gradient(to_bottom,transparent_72%,#2a2622_98%)]" aria-hidden="true"></div>

	<!-- Aurora glow — dual radial blobs (violet + amber) for brand warmth over the photo -->
	<div class="absolute inset-0 z-[2] pointer-events-none glow-aurora" aria-hidden="true"></div>

	<div class="relative z-10 max-w-container mx-auto w-full px-6 lg:px-8">
		<div class="max-w-2xl lg:max-w-3xl text-left flex flex-col items-start gap-6">
			<!-- Award badge — strongest single trust signal for German B2B audience -->
			<a href={currentLang === 'de' ? '/de#why-choose-us' : '/#why-choose-us'} class="inline-flex items-center gap-1.5 text-xs font-medium text-accent bg-accent/10 border border-accent/30 rounded-full px-3 py-1 hover:bg-accent/15 transition-colors no-underline">
				<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 6.4L21 9l-5 4.6L17.6 21 12 17.3 6.4 21 8 13.6 3 9l6.6-.6L12 2z"/></svg>
				{currentLang === 'en' ? 'BMWE KI-Preis 2025 Winner' : 'BMWE KI-Preis 2025 Gewinner'}
			</a>

			<!-- Headline — gradient on the last line (the "conclusion" sentence) -->
			<h1 class="text-display-sm md:text-display text-white m-0">
				{headlineLines.map((line, index) => (
					<>
						{index === headlineLines.length - 1 && headlineLines.length > 1
							? <span class="gradient-text-primary">{line}</span>
							: line}
						{index < headlineLines.length - 1 && <br />}
					</>
				))}
			</h1>

			<!-- Subheadline — full white at text-xl for Ausbilder readability -->
			<p class="text-xl leading-relaxed text-white max-w-2xl m-0">
				{subheadline}
			</p>

			<!-- Trust + compliance — single row, replaces the previous two-line cluster -->
			<p class="text-sm text-muted m-0 max-w-2xl">
				{currentLang === 'en'
					? '30+ German companies · GDPR-compliant · German-hosted · IHK-aligned'
					: '30+ Unternehmen · DSGVO-konform · Server in Deutschland · IHK-konform'}
			</p>

			<!-- CTA group: primary, secondary, Calendly fallback -->
			<div class="flex flex-col items-start gap-2 mt-2">
				<div class="flex flex-col sm:flex-row gap-3">
					<Button
						variant="primary"
						href="#demo-request"
						aria-label={ctaPrimary}
					>
						{ctaPrimary}
						<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</Button>
					<Button
						variant="secondary"
						href={currentLang === 'de' ? '/de/ausbildungskosten-rechner' : '/apprenticeship-savings-calculator'}
						aria-label={ctaSecondary}
						class="!border-white/40 !text-white hover:!border-white/60 backdrop-blur-sm"
					>
						{ctaSecondary}
					</Button>
				</div>

				<p class="text-xs text-muted/80 m-0">{currentLang === 'en' ? 'No-obligation · 30 minutes · no prep needed' : 'Unverbindlich · 30 Minuten · keine Vorbereitung nötig'}</p>

					<a href="https://calendly.com/learnslice-team/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-muted hover:text-white transition-colors">
					{currentLang === 'en' ? 'Or pick a 30-min slot directly' : 'Oder direkt einen 30-Min-Termin wählen'}
					<svg class="w-3.5 h-3.5 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
				</a>
			</div>

			<!-- Stat strip — proof points above-fold with amber numbers -->
			{stats.length > 0 && (
				<ul class="flex flex-wrap items-center justify-start gap-x-4 gap-y-2 mt-2 text-base text-muted m-0 p-0 list-none">
					{stats.map((stat, index) => (
						<>
							<li class="flex items-baseline gap-1.5">
								<span class="text-accent font-semibold">{stat.value}</span>
								<span>{stat.label}</span>
							</li>
							{index < stats.length - 1 && <li class="text-border-light" aria-hidden="true">·</li>}
						</>
					))}
				</ul>
			)}
		</div>
	</div>
</section>

<!-- App mockup — its own section below the photo hero, so it sits below the fold -->
<section class="relative bg-dark pt-2 md:pt-4 pb-16 md:pb-24" id="product-preview">
	<div class="max-w-container mx-auto w-full px-6 lg:px-8">
		<div class="relative p-4 md:p-12 rounded-3xl bg-gradient-to-b from-primary/15 to-primary/45 ring-1 ring-primary/25 overflow-hidden">
			<div class="relative shadow-xl mockup-scale-wrapper">
				<AppMockup currentLang={currentLang} />
			</div>
		</div>
	</div>
</section>

<style>
	@media (max-width: 767px) {
		.mockup-scale-wrapper {
			width: 180%;
			transform: scale(0.555);
			transform-origin: top left;
			margin-bottom: -45%;
		}
	}
</style>

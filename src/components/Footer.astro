---
interface Props {
	currentLang: 'en' | 'de';
	privacyLabel: string;
	termsLabel: string;
	imprintLabel?: string;
}

const { currentLang, privacyLabel, termsLabel, imprintLabel } = Astro.props;

const currentYear = new Date().getFullYear();
const basePath = currentLang === 'de' ? '/de' : '';
const defaultImprintLabel = currentLang === 'de' ? 'Impressum' : 'Imprint';

const footerColumns = currentLang === 'en'
	? {
		product: {
			title: 'Product',
			links: [
				{ label: 'Home', href: '/' },
				{ label: 'Savings Calculator', href: '/apprenticeship-savings-calculator' },
				{ label: 'Blog', href: '/blog' },
				{ label: 'Request Demo', href: '#demo-request' },
			],
		},
		useCases: {
			title: 'Use Cases',
			links: [
				{ label: 'For Companies', href: '/companies' },
				{ label: 'For Schools', href: '/schools' },
				{ label: 'For Agencies', href: '/agencies' },
			],
		},
		compare: {
			title: 'Compare',
			links: [
				{ label: 'vs. Traditional Training', href: '/learnslice-vs-traditional-training' },
				{ label: 'vs. Simpleclub', href: '/learnslice-vs-simpleclub' },
				{ label: 'vs. Prozubi', href: '/learnslice-vs-prozubi' },
				{ label: 'vs. Cornelsen eCademy', href: '/learnslice-vs-cornelsen-ecademy' },
				{ label: 'vs. Vocanto', href: '/learnslice-vs-vocanto' },
			],
		},
		legal: {
			title: 'Legal',
			links: [
				{ label: privacyLabel, href: '/privacy' },
				{ label: termsLabel, href: '/terms' },
				{ label: imprintLabel || defaultImprintLabel, href: '/imprint' },
			],
		},
	}
	: {
		product: {
			title: 'Produkt',
			links: [
				{ label: 'Startseite', href: '/de' },
				{ label: 'Einsparungsrechner', href: '/de/ausbildungskosten-rechner' },
				{ label: 'Blog', href: '/de/blog' },
				{ label: 'Demo anfordern', href: '#demo-request' },
			],
		},
		useCases: {
			title: 'Use Cases',
			links: [
				{ label: 'Für Unternehmen', href: '/de/companies' },
				{ label: 'Für Schulen', href: '/de/schools' },
				{ label: 'Für Agenturen', href: '/de/agencies' },
			],
		},
		compare: {
			title: 'Vergleich',
			links: [
				{ label: 'vs. Traditionelle Ausbildung', href: '/de/learnslice-vs-traditionelle-ausbildung' },
				{ label: 'vs. Simpleclub', href: '/de/learnslice-vs-simpleclub' },
				{ label: 'vs. Prozubi', href: '/de/learnslice-vs-prozubi' },
				{ label: 'vs. Cornelsen eCademy', href: '/de/learnslice-vs-cornelsen-ecademy' },
				{ label: 'vs. Vocanto', href: '/de/learnslice-vs-vocanto' },
			],
		},
		legal: {
			title: 'Rechtliches',
			links: [
				{ label: privacyLabel, href: '/de/privacy' },
				{ label: termsLabel, href: '/de/terms' },
				{ label: imprintLabel || defaultImprintLabel, href: '/de/imprint' },
			],
		},
	};

const columns = Object.values(footerColumns);
---

<footer class="py-16 px-6 md:px-8 border-t border-border">
	<div class="max-w-container mx-auto">
		<div class="flex flex-col gap-12">
			<!-- Top -->
			<div class="grid grid-cols-2 md:grid-cols-5 gap-8">
				<div class="col-span-2 md:col-span-1">
					<a href={currentLang === 'en' ? '/' : '/de'} class="flex items-center no-underline mb-4">
						<img
							src="/images/learnslice-logo.svg"
							alt="LearnSlice"
							class="h-7 w-auto"
							width="120"
							height="28"
						/>
					</a>
					<p class="text-muted text-xs leading-relaxed m-0 mb-4">
						{currentLang === 'en'
							? 'AI-powered apprenticeship training. Made in Germany.'
							: 'KI-gestützte Ausbildung. Made in Germany.'}
					</p>
					<div class="flex items-center gap-3">
						<a href="https://www.linkedin.com/company/49113282" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-muted hover:text-white transition-colors">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</a>
						<a href="https://www.instagram.com/learnslice" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-muted hover:text-white transition-colors">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C16.67.014 16.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
						</a>
					</div>
				</div>

				{columns.map(column => (
					<div>
						<h4 class="font-mono text-label uppercase tracking-widest text-muted mb-4">
							{column.title}
						</h4>
						<ul class="list-none m-0 p-0 flex flex-col gap-2.5">
							{column.links.map(link => (
								<li>
									<a
										href={link.href}
										class="text-muted hover:text-white transition-colors text-sm"
									>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>

			<!-- Divider -->
			<div class="border-t border-border"></div>

			<!-- Bottom -->
			<div class="flex flex-col md:flex-row items-center justify-between gap-2">
				<p class="text-muted text-xs m-0">
					&copy; {currentYear} LearnSlice UG (haftungsbeschr&auml;nkt)
				</p>
				<p class="text-muted text-xs m-0">
					{currentLang === 'en' ? 'D\u00FCsseldorf, Germany' : 'D\u00FCsseldorf, Deutschland'}
				</p>
			</div>
		</div>
	</div>
</footer>

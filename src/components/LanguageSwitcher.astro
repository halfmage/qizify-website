---
import { getAlternatePath } from '../utils/i18n';

interface Props {
	currentLang: 'en' | 'de';
	currentPath: string;
}

const { currentLang, currentPath } = Astro.props;

const alternatePath = getAlternatePath(currentPath, currentLang);
---

<nav class="flex items-center gap-1 font-mono text-xs" aria-label="Language selection">
	<a
		href={currentLang === 'en' ? '#' : alternatePath}
		class={`no-underline py-1 px-1.5 rounded transition-colors duration-200 ${currentLang === 'en' ? 'text-white pointer-events-none' : 'text-muted hover:text-white'}`}
		aria-current={currentLang === 'en' ? 'page' : undefined}
		aria-label="Switch to English"
	>
		EN
	</a>
	<span class="text-border-light select-none" aria-hidden="true">/</span>
	<a
		href={currentLang === 'de' ? '#' : alternatePath}
		class={`no-underline py-1 px-1.5 rounded transition-colors duration-200 ${currentLang === 'de' ? 'text-white pointer-events-none' : 'text-muted hover:text-white'}`}
		aria-current={currentLang === 'de' ? 'page' : undefined}
		aria-label="Switch to German"
	>
		DE
	</a>
</nav>

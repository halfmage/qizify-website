---
import Button from './Button.astro';

interface Props {
	currentLang: 'en' | 'de';
}

const { currentLang } = Astro.props;

const content = {
	en: {
		label: 'Calculator',
		headline: 'How much could you save?',
		description: 'Use our free calculator to see what apprenticeship dropouts and slow onboarding cost your company.',
		button: 'Open Savings Calculator',
		href: '/apprenticeship-savings-calculator',
	},
	de: {
		label: 'Rechner',
		headline: 'Wie viel k\u00F6nnten Sie sparen?',
		description: 'Berechnen Sie kostenlos, was Ausbildungsabbr\u00FCche und langsames Onboarding Ihr Unternehmen kosten.',
		button: 'Einsparungsrechner \u00F6ffnen',
		href: '/de/ausbildungskosten-rechner',
	},
};

const t = content[currentLang];
---

<section class="py-16 md:py-24 px-6 md:px-8" id="lead-capture">
	<div class="max-w-xl mx-auto">
		<div class="bg-surface border border-border rounded-xl p-8 flex flex-col gap-4">
			<span class="section-label">{t.label}</span>
			<h3 class="text-heading-sm text-white m-0">
				{t.headline}
			</h3>
			<p class="text-sm text-muted m-0 leading-relaxed">
				{t.description}
			</p>
			<div class="mt-2">
				<Button variant="primary" href={t.href}>
					{t.button}
					<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</Button>
			</div>
		</div>
	</div>
</section>

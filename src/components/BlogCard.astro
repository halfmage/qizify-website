---
interface Props {
	title: string;
	description: string;
	publishDate: Date;
	tags: string[];
	slug: string;
	lang: 'en' | 'de';
}

const { title, description, publishDate, tags, slug, lang } = Astro.props;

const basePath = lang === 'de' ? '/de' : '';
const href = `${basePath}/blog/${slug}`;

const formattedDate = publishDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<a href={href} class="group block bg-surface border border-border rounded-lg p-6 md:p-8 hover:border-border-light transition-colors duration-200">
	{tags.length > 0 && (
		<div class="flex flex-wrap gap-3 mb-4">
			{tags.map(tag => (
				<span class="section-label">{tag}</span>
			))}
		</div>
	)}

	<h3 class="text-base md:text-lg font-semibold text-white mb-3 group-hover:text-primary transition-colors duration-200 leading-snug">
		{title}
	</h3>

	<p class="text-muted text-sm leading-relaxed mb-4 line-clamp-3">
		{description}
	</p>

	<time datetime={publishDate.toISOString()} class="text-muted text-xs font-mono">
		{formattedDate}
	</time>
</a>

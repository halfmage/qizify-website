---
interface Props {
	title: string;
	description: string;
	publishDate: Date;
	tags: string[];
	slug: string;
	lang: 'en' | 'de';
}

const { title, description, publishDate, tags, slug, lang } = Astro.props;

const basePath = lang === 'de' ? '/de' : '';
const href = `${basePath}/blog/${slug}`;

const formattedDate = publishDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<a href={href} class="group block bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8 hover:border-primary/50 transition-all duration-300">
	{tags.length > 0 && (
		<div class="flex flex-wrap gap-2 mb-3">
			{tags.map(tag => (
				<span class="px-2 py-0.5 bg-primary/20 border border-primary/40 rounded-full text-primary text-xs font-medium uppercase tracking-wider">
					{tag}
				</span>
			))}
		</div>
	)}

	<h3 class="text-xl md:text-2xl font-bold text-white mb-3 group-hover:text-primary transition-colors leading-tight">
		{title}
	</h3>

	<p class="text-white/70 text-sm md:text-base leading-relaxed mb-4 line-clamp-3">
		{description}
	</p>

	<time datetime={publishDate.toISOString()} class="text-white/50 text-sm">
		{formattedDate}
	</time>
</a>

---
interface Testimonial {
	name: string;
	title: string;
	company: string;
	quote: string;
}

interface Props {
	headline: string;
	items: Testimonial[];
	currentLang: 'en' | 'de';
	featured?: Testimonial;
}

const { headline, items, currentLang, featured } = Astro.props;

const testimonialImages: Record<string, string> = {
	'Lienne Julie Wolff': 'lienne-julie-wolff.webp',
	'Kinga Patrycja Peters': 'kinga-patrycja-peters.webp',
	'Philipp Schulte': 'philipp-schulte.webp',
	'Prof. Dr. Carsten Wolff': 'carsten-wolff.webp',
};
---

<section class="py-20 md:py-32 px-6 md:px-8" id="testimonials">
	<div class="max-w-container mx-auto">
		<div class="text-center mb-16 md:mb-20">
			<span class="section-label mb-4 block">Testimonials</span>
			<h2 class="text-heading md:text-display-sm text-white m-0 max-w-[800px] mx-auto">
				{headline}
			</h2>
		</div>

		{featured && (
			<div class="mb-8 bg-surface border border-accent/30 rounded-xl p-8 md:p-12 relative overflow-hidden">
				<span class="absolute top-6 right-8 text-accent/30 font-serif text-7xl leading-none select-none pointer-events-none" aria-hidden="true">&ldquo;</span>
				<blockquote class="text-lg md:text-xl leading-relaxed text-white m-0 max-w-4xl relative">
					"{featured.quote}"
				</blockquote>
				<div class="flex items-center gap-4 pt-6 mt-6 border-t border-border">
					<div class="w-14 h-14 rounded-full overflow-hidden bg-border flex-shrink-0 ring-2 ring-accent/30 ring-offset-2 ring-offset-surface">
						<img
							src={`/images/testimonials/${testimonialImages[featured.name] || 'placeholder.webp'}`}
							alt={featured.name}
							class="w-full h-full object-cover"
							loading="lazy"
							width="112"
							height="112"
						/>
					</div>
					<div class="flex flex-col">
						<span class="text-base font-semibold text-white">{featured.name}</span>
						<span class="text-sm text-muted">{featured.title}, {featured.company}</span>
					</div>
				</div>
			</div>
		)}

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
			{items.map((testimonial) => {
				const imageFile = testimonialImages[testimonial.name] || 'placeholder.webp';
				return (
					<div class="bg-surface p-8 md:p-10 flex flex-col gap-6 relative">
						<span class="absolute top-4 right-5 text-accent/40 font-serif text-5xl leading-none select-none pointer-events-none" aria-hidden="true">&ldquo;</span>
						<blockquote class="text-base leading-relaxed text-white/85 m-0 flex-1 relative">
							"{testimonial.quote}"
						</blockquote>
						<div class="flex items-center gap-4 pt-4 border-t border-border">
							<div class="w-10 h-10 rounded-full overflow-hidden bg-border flex-shrink-0 ring-2 ring-accent/30 ring-offset-2 ring-offset-surface">
								<img
									src={`/images/testimonials/${imageFile}`}
									alt={`${testimonial.name}`}
									class="w-full h-full object-cover"
									loading="lazy"
									width="80"
									height="80"
								/>
							</div>
							<div class="flex flex-col">
								<span class="text-base font-medium text-white">{testimonial.name}</span>
								<span class="text-xs text-muted">{testimonial.title}, {testimonial.company}</span>
							</div>
						</div>
					</div>
				);
			})}
		</div>
	</div>
</section>

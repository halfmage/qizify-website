---
import Button from './Button.astro';
import { Icon } from 'astro-icon/components';

interface Props {
	currentLang: 'en' | 'de';
}

const { currentLang } = Astro.props;

const consent = currentLang === 'en'
	? { privacy: '/privacy', terms: '/terms' }
	: { privacy: '/de/privacy', terms: '/de/terms' };

const roles = currentLang === 'en'
	? ['Management', 'Pedagogical lead', 'Quality management / AZAV', 'IT / digitalisation', 'Other']
	: ['Geschäftsführung', 'Pädagogische Leitung', 'Qualitätsmanagement / AZAV', 'IT / Digitalisierung', 'Sonstige'];

const c = currentLang === 'en'
	? {
		label: 'Free digital check',
		headline: 'Where does your digital offering stand on BFSG and AZAV?',
		sub: 'The 12-point check shows you in three minutes where you are compliant and where you need to act. Visible immediately after you enter your details.',
		teaserTitle: 'What is inside',
		teaser: [
			'Accessibility under BFSG and WCAG 2.1 AA',
			'AZAV documentation and synchronous learning time',
			'AI use and data sovereignty',
		],
		nameLabel: 'Name',
		emailLabel: 'Email',
		orgLabel: 'Organisation (optional)',
		roleLabel: 'Your role (optional)',
		submit: 'Show the digital check',
		micro: 'Free · no spam · unsubscribe anytime',
		error: 'An error occurred. Please try again or contact us directly.',
		resultTitle: 'Your digital check',
		resultIntro: 'Work through the twelve points. Every Yes puts you a step ahead.',
		sections: [
			{ title: 'A. Accessibility (BFSG)', items: [
				'Does your learning platform meet WCAG 2.1 AA (keyboard use, contrast, screen reader)?',
				'Do you have a plan for the transition period to 2030 for existing offerings?',
				'Are your learning contents (PDF, video, quiz) prepared accessibly?',
				'Is accessibility part of your procurement and tender criteria?',
			] },
			{ title: 'B. AZAV documentation', items: [
				'Do you record synchronous instruction time separately from self-study time?',
				'Do you capture attendance and learning progress audit-proof and exportable?',
				'Is outcome monitoring (incl. placement) documented systematically?',
				'Are digital formats covered in your measure accreditation?',
			] },
			{ title: 'C. AI and data sovereignty', items: [
				'Do you use AI learning support grounded in your verified content?',
				'Is learner data processed in Germany or the EU, with a DPA?',
				'Is it ensured that no learner data flows into training third-party models?',
				'Does your AI use meet the EU AI Act requirements (oversight, transparency)?',
			] },
		],
		resultCta: 'Found gaps? Let us turn them into a concrete roadmap.',
		resultButton: 'Book a strategy call',
	}
	: {
		label: 'Kostenloser Digitalcheck',
		headline: 'Wo steht Ihr digitales Angebot bei BFSG und AZAV?',
		sub: 'Der 12-Punkte-Check zeigt Ihnen in drei Minuten, wo Sie compliant sind und wo Handlungsbedarf besteht. Sofort sichtbar nach dem Eintragen.',
		teaserTitle: 'Was drin ist',
		teaser: [
			'Barrierefreiheit nach BFSG und WCAG 2.1 AA',
			'AZAV-Dokumentation und synchrone Lernzeit',
			'KI-Einsatz und Datensouveränität',
		],
		nameLabel: 'Name',
		emailLabel: 'E-Mail',
		orgLabel: 'Organisation (optional)',
		roleLabel: 'Ihre Rolle (optional)',
		submit: 'Digitalcheck anzeigen',
		micro: 'Kostenlos · kein Spam · jederzeit abbestellbar',
		error: 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt.',
		resultTitle: 'Ihr Digitalcheck',
		resultIntro: 'Gehen Sie die zwölf Punkte durch. Pro Ja-Antwort sind Sie einen Schritt weiter.',
		sections: [
			{ title: 'A. Barrierefreiheit (BFSG)', items: [
				'Erfüllt Ihre Lernplattform WCAG 2.1 AA (Tastaturbedienung, Kontraste, Screenreader)?',
				'Haben Sie einen Plan für die Übergangsfrist bis 2030 für bestehende Angebote?',
				'Sind Ihre Lerninhalte (PDF, Video, Quiz) barrierearm aufbereitet?',
				'Ist Barrierefreiheit Teil Ihrer Beschaffungs- und Vergabekriterien?',
			] },
			{ title: 'B. AZAV-Dokumentation', items: [
				'Weisen Sie synchrone Unterrichtszeit getrennt von der Selbstlernzeit nach?',
				'Erfassen Sie Anwesenheit und Lernfortschritt prüfsicher und exportierbar?',
				'Ist die Erfolgskontrolle (inklusive Verbleib) systematisch dokumentiert?',
				'Sind digitale Formate in Ihrer Maßnahmezulassung abgedeckt?',
			] },
			{ title: 'C. KI und Datensouveränität', items: [
				'Setzen Sie KI-Lernbegleitung ein, die auf Ihren geprüften Inhalten basiert?',
				'Werden Lernerdaten in Deutschland oder der EU verarbeitet, mit AVV?',
				'Ist sichergestellt, dass keine Lernerdaten in das Training von Dritt-Modellen fließen?',
				'Erfüllt Ihr KI-Einsatz die Anforderungen der EU-KI-Verordnung (Aufsicht, Transparenz)?',
			] },
		],
		resultCta: 'Lücken entdeckt? Lassen Sie uns daraus eine konkrete Roadmap machen.',
		resultButton: 'Strategiegespräch buchen',
	};
---

<!-- Hidden HTML form for Netlify Forms detection -->
<form name="digitalcheck" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="hidden">
	<input type="hidden" name="form-name" value="digitalcheck" />
	<input type="text" name="name" />
	<input type="email" name="email" />
	<input type="text" name="organisation" />
	<input type="text" name="role" />
	<input type="checkbox" name="consent" />
	<input type="text" name="bot-field" />
</form>

<section id="digitalcheck" class="py-12 md:py-20 px-6 md:px-8 scroll-mt-24">
	<div class="max-w-container mx-auto">
		<!-- Intro: teaser + capture form -->
		<div id="digitalcheck-intro" class="relative">
			<div class="absolute -inset-4 glow-aurora opacity-40 pointer-events-none" aria-hidden="true"></div>
			<div class="relative grid md:grid-cols-2 gap-8 md:gap-12 items-center bg-surface border border-border rounded-2xl p-8 md:p-12 overflow-hidden">
				<div>
					<span class="section-label mb-4 block">{c.label}</span>
					<h2 class="text-heading md:text-display-sm text-white m-0 mb-3">{c.headline}</h2>
					<p class="text-base text-muted leading-relaxed m-0 mb-6">{c.sub}</p>
					<p class="text-xs font-mono uppercase tracking-wider text-primary mb-3">{c.teaserTitle}</p>
					<ul class="flex flex-col gap-2.5 list-none p-0 m-0">
						{c.teaser.map((item) => (
							<li class="flex items-start gap-3 text-sm text-white/90">
								<Icon name="hugeicons:checkmark-circle-02" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>

				<form class="flex flex-col gap-4" id="digitalcheck-form" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-error-text={c.error}>
					<input type="hidden" name="form-name" value="digitalcheck" />
					<input type="text" name="bot-field" class="hidden" />

					<div class="flex flex-col gap-1.5">
						<label for="dc-name" class="text-sm font-medium text-white/80">{c.nameLabel}</label>
						<input type="text" id="dc-name" name="name" required aria-required="true" class="bg-input-bg border border-border-light rounded-lg px-4 py-2.5 text-sm text-white font-sans w-full focus:outline-none focus:border-primary transition-colors duration-200" />
					</div>

					<div class="flex flex-col gap-1.5">
						<label for="dc-email" class="text-sm font-medium text-white/80">{c.emailLabel}</label>
						<input type="email" id="dc-email" name="email" required aria-required="true" class="bg-input-bg border border-border-light rounded-lg px-4 py-2.5 text-sm text-white font-sans w-full focus:outline-none focus:border-primary transition-colors duration-200" />
					</div>

					<div class="flex flex-col gap-1.5">
						<label for="dc-org" class="text-sm font-medium text-white/80">{c.orgLabel}</label>
						<input type="text" id="dc-org" name="organisation" class="bg-input-bg border border-border-light rounded-lg px-4 py-2.5 text-sm text-white font-sans w-full focus:outline-none focus:border-primary transition-colors duration-200" />
					</div>

					<div class="flex flex-col gap-1.5">
						<label for="dc-role" class="text-sm font-medium text-white/80">{c.roleLabel}</label>
						<select id="dc-role" name="role" class="bg-input-bg border border-border-light rounded-lg px-4 py-2.5 text-sm text-white font-sans w-full focus:outline-none focus:border-primary transition-colors duration-200">
							{roles.map((r) => (<option value={r}>{r}</option>))}
						</select>
					</div>

					<label class="flex items-start gap-2.5 cursor-pointer text-xs text-muted leading-relaxed">
						<input type="checkbox" id="dc-consent" name="consent" required aria-required="true" class="mt-0.5 w-4 h-4 flex-shrink-0 cursor-pointer accent-primary" />
						<span class="flex-1">
							{currentLang === 'en' ? (
								<>I agree to the <a href={consent.privacy} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Privacy Policy</a> and <a href={consent.terms} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Terms of Use</a>.</>
							) : (
								<>Ich stimme der <a href={consent.privacy} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Datenschutzerkl&auml;rung</a> und den <a href={consent.terms} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Nutzungsbedingungen</a> zu.</>
							)}
						</span>
					</label>

					<div class="hidden p-3 rounded-lg text-xs bg-red-500/10 border border-red-500/20 text-red-300" id="dc-error" role="alert"></div>

					<button type="submit" class="bg-primary text-white border-none rounded-lg px-6 py-2.5 text-sm font-medium cursor-pointer hover:bg-[#6a4ae0] active:bg-[#5c3dd4] transition-all duration-200 font-sans mt-1 disabled:opacity-50 disabled:cursor-not-allowed">
						{c.submit}
					</button>
					<p class="text-xs text-muted text-center -mt-1">{c.micro}</p>
				</form>
			</div>
		</div>

		<!-- Result: the checklist, revealed after submit -->
		<div id="digitalcheck-result" class="hidden relative">
			<div class="absolute -inset-4 glow-aurora opacity-40 pointer-events-none" aria-hidden="true"></div>
			<div class="relative bg-surface border border-border rounded-2xl p-8 md:p-12 overflow-hidden">
				<span class="section-label mb-4 block">{c.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-3">{c.resultTitle}</h2>
				<p class="text-base text-muted leading-relaxed m-0 mb-8">{c.resultIntro}</p>
				<div class="grid md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
					{c.sections.map((sec) => (
						<div class="bg-surface p-6">
							<div class="text-xs font-mono uppercase tracking-wider text-primary mb-4">{sec.title}</div>
							<ul class="flex flex-col gap-3 list-none p-0 m-0">
								{sec.items.map((item) => (
									<li class="flex items-start gap-3 text-sm text-white/90">
										<Icon name="hugeicons:checkmark-circle-02" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
										<span>{item}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
				<div class="flex flex-col sm:flex-row sm:items-center gap-4 mt-8">
					<p class="text-base text-white/90 m-0 flex-1">{c.resultCta}</p>
					<Button variant="primary" href="#project-inquiry" data-modal-trigger="project-inquiry" aria-label={c.resultButton}>{c.resultButton}</Button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	function initDigitalCheck() {
		const form = document.getElementById('digitalcheck-form') as HTMLFormElement | null;
		const intro = document.getElementById('digitalcheck-intro');
		const result = document.getElementById('digitalcheck-result');
		const errorMessage = document.getElementById('dc-error');
		if (!form || !intro || !result) return;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (errorMessage) errorMessage.classList.add('hidden');
			const formData = new FormData(form);
			try {
				const response = await fetch('/', {
					method: 'POST',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams(formData as any).toString(),
				});
				if (!response.ok) throw new Error('Form submission failed');
				intro.classList.add('hidden');
				result.classList.remove('hidden');
				result.scrollIntoView({ behavior: 'smooth', block: 'start' });
			} catch (error) {
				if (errorMessage) {
					errorMessage.textContent = errorMessage.getAttribute('data-error') || 'An error occurred. Please try again.';
					errorMessage.classList.remove('hidden');
				}
			}
		});

		if (errorMessage) errorMessage.setAttribute('data-error', form.getAttribute('data-error-text') || '');
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDigitalCheck);
	} else {
		initDigitalCheck();
	}
</script>

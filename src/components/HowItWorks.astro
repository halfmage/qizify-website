---
interface Step {
	number: string;
	title: string;
	description: string;
}

interface Props {
	badge: string;
	headline: string;
	steps: Step[];
}

const { badge, headline, steps } = Astro.props;

const stepImages = [
	"/images/screenshots/learnslice-copilot-02.jpg",
	"/images/screenshots/learnslice-copilot-03.jpg",
	"/images/screenshots/learnslice-copilot-06.jpg",
];

const getStepImage = (index: number) => stepImages[index] || stepImages[0];
---

<section class="py-20 md:py-32 px-6 md:px-8" id="how-it-works">
	<div class="max-w-container mx-auto">
		<div class="text-center mb-16 md:mb-20">
			<span class="section-label mb-4 block">{badge}</span>
			<h2 class="text-heading md:text-display-sm text-white m-0 max-w-[800px] mx-auto">
				{headline}
			</h2>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
			<!-- Steps -->
			<div class="flex flex-col gap-2" id="how-it-works-tabs">
				{steps.map((step, index) => (
					<button
						class:list={[
							"how-it-works-tab group",
							"bg-transparent border border-transparent rounded-lg p-5 flex gap-5 items-start text-left transition-all duration-200 cursor-pointer",
							index === 0 ? "border-border-light bg-surface active" : "hover:bg-surface/50"
						]}
						data-tab-index={index}
						data-image={getStepImage(index)}
						aria-selected={index === 0 ? "true" : "false"}
					>
						<span class:list={[
							"font-mono text-label mt-1 flex-shrink-0 transition-colors duration-200",
							index === 0 ? "text-primary" : "text-muted"
						]}>
							0{step.number}
						</span>
						<div class="flex-1 flex flex-col gap-2">
							<h3 class:list={[
								"text-base font-semibold m-0 leading-tight transition-colors duration-200",
								index === 0 ? "text-white" : "text-muted"
							]}>
								{step.title}
							</h3>
							<p class:list={[
								"text-sm leading-relaxed m-0 transition-all duration-200 hidden md:block",
								index === 0 ? "text-muted opacity-100 max-h-40" : "text-muted opacity-0 max-h-0 overflow-hidden"
							]}>
								{step.description}
							</p>
						</div>
					</button>
				))}
			</div>

			<!-- Image -->
			<div class="relative rounded-xl overflow-hidden border border-border-light" id="how-it-works-image-panel">
				<img
					src={stepImages[0]}
					alt="LearnSlice platform interface"
					class="w-full h-auto block transition-opacity duration-300"
					loading="lazy"
					width="1200"
					height="800"
					id="how-it-works-image"
				/>
			</div>
		</div>
	</div>
</section>

<script>
	function initHowItWorksTabs() {
		const tabs = document.querySelectorAll('.how-it-works-tab');
		const image = document.getElementById('how-it-works-image') as HTMLImageElement;

		if (!tabs.length || !image) return;

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				tabs.forEach((t) => {
					t.classList.remove('active', 'border-border-light', 'bg-surface');
					t.classList.add('border-transparent');
					t.setAttribute('aria-selected', 'false');
					const num = t.querySelector('span:first-child');
					const title = t.querySelector('h3');
					const desc = t.querySelector('p');
					if (num) { num.classList.remove('text-primary'); num.classList.add('text-muted'); }
					if (title) { title.classList.remove('text-white'); title.classList.add('text-muted'); }
					if (desc) { desc.classList.remove('opacity-100', 'max-h-40'); desc.classList.add('opacity-0', 'max-h-0', 'overflow-hidden'); }
				});

				tab.classList.add('active', 'border-border-light', 'bg-surface');
				tab.classList.remove('border-transparent');
				tab.setAttribute('aria-selected', 'true');
				const num = tab.querySelector('span:first-child');
				const title = tab.querySelector('h3');
				const desc = tab.querySelector('p');
				if (num) { num.classList.remove('text-muted'); num.classList.add('text-primary'); }
				if (title) { title.classList.remove('text-muted'); title.classList.add('text-white'); }
				if (desc) { desc.classList.remove('opacity-0', 'max-h-0', 'overflow-hidden'); desc.classList.add('opacity-100', 'max-h-40'); }

				const newImageSrc = tab.getAttribute('data-image');
				if (newImageSrc && image.src !== newImageSrc) {
					image.style.opacity = '0';
					setTimeout(() => {
						image.src = newImageSrc;
						image.style.opacity = '1';
					}, 150);
				}
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initHowItWorksTabs);
	document.addEventListener('astro:page-load', initHowItWorksTabs);
</script>

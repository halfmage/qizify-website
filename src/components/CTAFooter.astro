---
import Button from './Button.astro';

interface Props {
	headline: string;
	subheadline: string;
	button: string;
	currentLang: 'en' | 'de';
}

const { headline, subheadline, button, currentLang } = Astro.props;

const subheadlineLines = subheadline.split('\n');
---

<section class="py-20 md:py-32 px-6 md:px-8 relative overflow-hidden" id="cta-footer">
	<!-- Subtle glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.3) 0%, transparent 70%);"></div>

	<div class="max-w-xl mx-auto relative z-10 text-center flex flex-col items-center gap-6">
		<span class="section-label">Get Started</span>
		<h2 class="text-heading md:text-display-sm text-white m-0">
			{headline}
		</h2>
		<p class="text-base leading-relaxed text-muted m-0">
			{subheadlineLines.map((line, index) => (
				<>
					{line}
					{index < subheadlineLines.length - 1 && <br />}
				</>
			))}
		</p>
		<div class="mt-2">
			<Button
				variant="primary"
				href="#demo-request"
				aria-label={button}
			>
				{button}
				<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
			</Button>
		</div>
	</div>
</section>

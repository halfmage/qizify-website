---
import { Icon } from 'astro-icon/components';

interface Feature {
	icon: string;
	title: string;
	description: string;
}

interface Props {
	badge: string;
	headline: string;
	features: Feature[];
	compliance: string;
}

const { badge, headline, features, compliance } = Astro.props;
---

<section class="py-20 md:py-32 px-6 md:px-8" id="learning-results">
	<div class="max-w-container mx-auto">
		<div class="text-center mb-16 md:mb-20">
			<span class="section-label mb-4 block">{badge}</span>
			<h2 class="text-heading md:text-display-sm text-white m-0 max-w-[800px] mx-auto">
				{headline}
			</h2>
		</div>

		<!-- Screenshot -->
		<div class="relative mb-16 md:mb-20">
			<div class="absolute -inset-8 opacity-30 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.15) 0%, transparent 70%);"></div>
			<div class="relative rounded-xl overflow-hidden border border-border-light shadow-2xl shadow-primary/5 max-w-4xl mx-auto">
				<img
					src="/images/screenshots/learnslice-copilot-02.jpg"
					alt="LearnSlice platform interface"
					class="w-full h-auto block"
					loading="lazy"
					width="1200"
					height="800"
				/>
			</div>
		</div>

		<!-- Feature grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-border rounded-xl overflow-hidden mb-12">
			{features.map((feature) => (
				<div class="bg-surface p-6 md:p-8 flex flex-col gap-4 group hover:bg-[#151517] transition-colors duration-200">
					<div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary/10 group-hover:bg-primary/15 transition-colors duration-200">
						<Icon name={feature.icon} class="w-5 h-5 text-primary" />
					</div>
					<h3 class="text-base font-semibold text-white m-0 leading-snug">
						{feature.title}
					</h3>
					<p class="text-sm leading-relaxed text-muted m-0">
						{feature.description}
					</p>
				</div>
			))}
		</div>

		<p class="text-center text-sm text-muted m-0 font-mono">
			{compliance}
		</p>
	</div>
</section>

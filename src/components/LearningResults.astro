---
import { Icon } from 'astro-icon/components';
import { highlightNumbers } from '../utils/highlight-numbers.mjs';

interface Feature {
	icon: string;
	title: string;
	description: string;
}

interface Props {
	badge: string;
	headline: string;
	features: Feature[];
	compliance: string;
}

const { badge, headline, features, compliance } = Astro.props;
---

<section class="py-20 md:py-32 px-6 md:px-8 overflow-x-clip" id="learning-results">
	<div class="max-w-container mx-auto">
		<div class="text-center mb-16 md:mb-20">
			<span class="section-label mb-4 block">{badge}</span>
			<h2 class="text-heading md:text-display-sm text-white m-0 max-w-[800px] mx-auto">
				{headline}
			</h2>
		</div>

		<!-- Screenshot — dual-tone glow for warmth -->
		<div class="relative mb-16 md:mb-20">
			<div class="absolute -inset-8 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 60% 60% at 30% 50%, rgba(124, 92, 252, 0.28) 0%, transparent 70%), radial-gradient(ellipse 50% 55% at 75% 60%, rgba(244, 162, 97, 0.22) 0%, transparent 70%);"></div>
			<div class="relative rounded-xl overflow-hidden border border-border-light shadow-2xl shadow-primary/10 max-w-4xl mx-auto">
				<img
					src="/images/screenshots/learnslice-copilot-02.jpg"
					alt="LearnSlice platform interface"
					class="w-full h-auto block"
					loading="lazy"
					width="1200"
					height="800"
				/>
			</div>
		</div>

		<!-- Feature grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-border rounded-xl overflow-hidden mb-12">
			{features.map((feature) => (
				<div class="card-hover-glow card-hover-glow-primary bg-surface p-6 md:p-8 flex flex-col gap-4 group hover:bg-[#403930] transition-colors duration-200">
					<div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary/10 group-hover:bg-primary/15 group-hover:scale-110 transition-all duration-200">
						<Icon name={feature.icon} class="w-5 h-5 text-primary" />
					</div>
					<h3 class="text-lg font-semibold text-white m-0 leading-snug">
						{feature.title}
					</h3>
					<p class="text-base leading-relaxed text-muted m-0">
						{feature.description}
					</p>
				</div>
			))}
		</div>

		<p class="text-center text-base text-muted m-0 font-mono" set:html={highlightNumbers(compliance)}></p>
	</div>
</section>

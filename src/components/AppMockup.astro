---
interface Props {
	currentLang: 'en' | 'de';
}

const { currentLang } = Astro.props;

const isDE = currentLang === 'de';

const chatItems = isDE
	? [
		{ title: 'IHK Prüfungssimulation', collection: 'Kaufmännisch', msgs: 12 },
		{ title: 'Buchhaltung Grundlagen', collection: 'Onboarding', msgs: 8 },
		{ title: 'Kundenreklamation üben', collection: 'Simulation', msgs: 5 },
		{ title: 'Vertragsrecht Basics', collection: 'IHK Modul 3', msgs: 3 },
	]
	: [
		{ title: 'IHK Exam Simulation', collection: 'Commercial', msgs: 12 },
		{ title: 'Accounting Fundamentals', collection: 'Onboarding', msgs: 8 },
		{ title: 'Customer Complaint Practice', collection: 'Simulation', msgs: 5 },
		{ title: 'Contract Law Basics', collection: 'IHK Module 3', msgs: 3 },
	];

const userMessage = isDE
	? 'Erkläre mir die doppelte Buchführung mit einem Beispiel'
	: 'Explain double-entry bookkeeping with an example';

const botGreeting = isDE
	? `Klar! Die <strong class="text-white">doppelte Buchführung</strong> bedeutet, dass jede Transaktion auf mindestens zwei Konten gebucht wird — einmal im <strong class="text-white">Soll</strong> und einmal im <strong class="text-white">Haben</strong>.`
	: `Sure! <strong class="text-white">Double-entry bookkeeping</strong> means every transaction is recorded in at least two accounts — once as a <strong class="text-white">debit</strong> and once as a <strong class="text-white">credit</strong>.`;

const botExample = isDE
	? 'Beispiel: Dein Unternehmen kauft Büromaterial für 200 €'
	: 'Example: Your company buys office supplies for €200';

const botItems = isDE
	? [
		{ label: 'Soll', value: 'Büromaterial +200 €' },
		{ label: 'Haben', value: 'Bank −200 €' },
	]
	: [
		{ label: 'Debit', value: 'Office Supplies +€200' },
		{ label: 'Credit', value: 'Bank −€200' },
	];

const botFollowup = isDE
	? 'Die Bilanz bleibt immer ausgeglichen. Soll ich ein Quiz dazu starten?'
	: 'The balance sheet always stays balanced. Want me to start a quiz on this?';

const inputPlaceholder = isDE ? 'Nachricht eingeben...' : 'Type your message...';
const newChatLabel = isDE ? 'Neuer Chat' : 'New Chat';
const sendLabel = isDE ? 'Senden' : 'Send';

// Knowledge screen
const kbItems = isDE
	? [
		{ name: 'IHK Prüfungsordnung', docs: 14, date: '21/03/2026' },
		{ name: 'Unternehmenshandbuch', docs: 8, date: '18/03/2026' },
		{ name: 'Produktkatalog 2026', docs: 3, date: '15/03/2026' },
	]
	: [
		{ name: 'IHK Exam Regulations', docs: 14, date: '21/03/2026' },
		{ name: 'Company Handbook', docs: 8, date: '18/03/2026' },
		{ name: 'Product Catalog 2026', docs: 3, date: '15/03/2026' },
	];

const kbTitle = isDE ? 'Wissensbasen' : 'Knowledge Bases';
const kbSub = isDE ? 'Wissenssammlungen für KI-gestütztes Lernen verwalten' : 'Manage knowledge collections for AI-powered learning';
const kbCount = isDE ? '3 / 10 Wissensbasen' : '3 / 10 Knowledge Bases';
const kbCreate = isDE ? 'Wissensbasis erstellen' : 'Create Knowledge Base';
const kbMyLabel = isDE ? 'Meine Wissensbasen' : 'My Knowledge Bases';
const kbDetails = isDE ? 'Details ansehen' : 'View details';
const kbDocs = isDE ? 'Dokumente:' : 'Documents:';
const kbCreated = isDE ? 'Erstellt:' : 'Created:';

// Assessment screen
const assessments = isDE
	? [
		{ name: 'Buchführung Grundlagen', desc: '15 Multiple-Choice-Fragen zu den Grundlagen...', type: 'Quiz', tag: 'Rechnungswesen', questions: 15, points: 280, date: '21.03.2026', best: '92%', attempts: 3, status: 'Active' },
		{ name: 'Kundenberatung Simulation', desc: 'Realistische Fallstudie zur Kundenberatung...', type: 'Case Study', tag: 'Vertrieb', questions: 5, points: 150, date: '19.03.2026', best: '78%', attempts: 2, status: 'Active' },
	]
	: [
		{ name: 'Accounting Fundamentals', desc: '15 multiple-choice questions covering core...', type: 'Quiz', tag: 'Accounting', questions: 15, points: 280, date: 'Mar 21, 2026', best: '92%', attempts: 3, status: 'Active' },
		{ name: 'Customer Advisory Simulation', desc: 'Realistic case study on customer advisory...', type: 'Case Study', tag: 'Sales', questions: 5, points: 150, date: 'Mar 19, 2026', best: '78%', attempts: 2, status: 'Active' },
	];

const assTitle = isDE ? 'Assessments' : 'Assessments';
const assSub = isDE ? 'Wissen testen mit Quizzes, Deep Dives und Fallstudien' : 'Test your knowledge with quizzes, deep dives, and case studies';
const assCount = isDE ? '2 Assessments' : '2 assessments';
const assPlay = isDE ? 'Erneut spielen' : 'Play Again';
const assAttempt = isDE ? 'Versuche' : 'attempts';

// Analytics screen
const anaTitle = isDE ? 'Analytics' : 'Analytics';
const anaSub = isDE ? 'Fortschritt und Leistung im Überblick' : 'Track progress and performance at a glance';
---

<div class="app-mockup w-full aspect-video rounded-xl border border-border-light overflow-hidden bg-dark shadow-2xl shadow-primary/10 select-none flex flex-col" aria-hidden="true">
	<!-- Top Nav -->
	<div class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface shrink-0">
		<img src="/images/learnslice-logo.svg" alt="LearnSlice" class="h-5 w-auto brightness-0 invert" />
		<div class="flex items-center gap-1">
			<button class="mockup-nav-tab mockup-nav-active" data-tab="chats">
				<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>
				Chats
			</button>
			<button class="mockup-nav-tab" data-tab="knowledge">
				<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
				Knowledge
			</button>
			<button class="mockup-nav-tab" data-tab="assessments">
				<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
				Assessments
			</button>
			<button class="mockup-nav-tab" data-tab="analytics">
				<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
				Analytics
			</button>
		</div>
		<span class="mockup-nav-tab pointer-events-none">
			<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
			Settings
		</span>
	</div>

	<!-- TAB: Chats -->
	<div class="mockup-panel flex flex-1 overflow-hidden" data-panel="chats">
		<!-- Sidebar -->
		<div class="hidden md:flex flex-col w-48 shrink-0 border-r border-border bg-surface/50 p-3 gap-2">
			<div class="w-full py-2 rounded-lg bg-primary text-white text-xs font-medium flex items-center justify-center gap-1.5">
				{newChatLabel}
				<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
			</div>
			<div class="flex flex-col gap-0.5 mt-1">
				{chatItems.map((item, i) => (
					<div class={`px-3 py-2 rounded-lg ${i === 0 ? 'bg-primary/10 border border-primary/20' : ''}`}>
						<div class={`text-xs font-medium truncate ${i === 0 ? 'text-white' : 'text-muted'}`}>{item.title}</div>
						<div class="text-[10px] text-muted mt-0.5">{item.collection} · {item.msgs} msgs</div>
					</div>
				))}
			</div>
		</div>

		<!-- Chat Area -->
		<div class="flex-1 flex flex-col">
			<div class="flex-1 px-4 md:px-6 py-5 flex flex-col gap-4 overflow-hidden max-w-xl mx-auto w-full">
				<!-- User message -->
				<div class="flex justify-end">
					<div class="bg-primary text-white text-xs px-4 py-2.5 rounded-2xl rounded-br-md max-w-[85%] leading-relaxed">
						{userMessage}
					</div>
				</div>

				<!-- Bot response -->
				<div class="flex flex-col gap-3">
					<p class="text-xs text-white/80 leading-relaxed m-0" set:html={botGreeting} />

					<div class="bg-surface border border-border rounded-lg p-3 flex flex-col gap-2">
						<span class="text-[10px] text-muted">{botExample}</span>
						<div class="flex flex-col gap-1.5">
							{botItems.map((item) => (
								<div class="flex items-center gap-2 text-xs">
									<span class="px-1.5 py-0.5 rounded bg-primary/15 text-primary font-mono text-[10px] font-medium">{item.label}</span>
									<span class="text-white/80">{item.value}</span>
								</div>
							))}
						</div>
					</div>

					<p class="text-xs text-white/80 leading-relaxed m-0">{botFollowup}</p>
				</div>
			</div>

			<!-- Input bar -->
			<div class="px-4 md:px-6 pb-4 flex flex-col gap-2 max-w-xl mx-auto w-full">
				<div class="flex items-center gap-2 bg-surface border border-border rounded-xl px-4 py-2.5">
					<span class="text-xs text-muted flex-1">{inputPlaceholder}</span>
					<svg class="w-4 h-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
					<div class="bg-primary text-white text-xs font-medium px-3 py-1.5 rounded-lg flex items-center gap-1.5">
						{sendLabel}
						<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
					</div>
				</div>
				<div class="flex items-center gap-2">
					<span class="mockup-pill mockup-pill-active">Company KB</span>
					<span class="mockup-pill">Personal KB</span>
					<span class="mockup-pill">Assessment</span>
				</div>
			</div>
		</div>
	</div>

	<!-- TAB: Knowledge -->
	<div class="mockup-panel hidden flex-1 overflow-hidden flex-col" data-panel="knowledge">
		<div class="px-6 py-5 border-b border-border flex items-start justify-between">
			<div>
				<h3 class="text-base font-semibold text-white m-0">{kbTitle}</h3>
				<p class="text-xs text-muted m-0 mt-1">{kbSub}</p>
			</div>
			<div class="flex items-center gap-2">
				<span class="text-[10px] text-muted">{kbCount}</span>
				<div class="bg-primary text-white text-xs font-medium px-3 py-1.5 rounded-lg flex items-center gap-1.5">
					<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
					{kbCreate}
				</div>
			</div>
		</div>
		<div class="px-6 py-5 flex-1">
			<div class="flex items-center gap-2 mb-4">
				<svg class="w-4 h-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
				<span class="text-sm font-medium text-white">{kbMyLabel}</span>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
				{kbItems.map((kb) => (
					<div class="bg-surface border border-border rounded-xl p-4 flex flex-col gap-3">
						<span class="text-sm font-medium text-white">{kb.name}</span>
						<div class="flex flex-col gap-1.5 text-xs">
							<div class="flex justify-between"><span class="text-muted">{kbDocs}</span><span class="text-white">{kb.docs}</span></div>
							<div class="flex justify-between"><span class="text-muted">{kbCreated}</span><span class="text-white">{kb.date}</span></div>
						</div>
						<div class="border-t border-border pt-2 mt-auto flex items-center justify-between">
							<span class="text-xs text-muted">{kbDetails}</span>
							<svg class="w-3.5 h-3.5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>

	<!-- TAB: Assessments -->
	<div class="mockup-panel hidden flex-1 overflow-hidden flex-col" data-panel="assessments">
		<div class="px-6 py-5 border-b border-border flex items-start justify-between">
			<div>
				<h3 class="text-base font-semibold text-white m-0">{assTitle}</h3>
				<p class="text-xs text-muted m-0 mt-1">{assSub}</p>
			</div>
			<div class="flex items-center gap-2">
				<span class="mockup-filter-pill">All Types</span>
				<span class="mockup-filter-pill">All Statuses</span>
			</div>
		</div>
		<div class="px-6 py-5 flex-1">
			<p class="text-xs text-muted mb-4 m-0">{assCount}</p>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
				{assessments.map((a) => (
					<div class="bg-surface border border-border rounded-xl p-4 flex flex-col gap-3">
						<div class="flex items-start justify-between gap-2">
							<div class="flex items-start gap-2">
								<div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
									<svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
								</div>
								<div>
									<span class="text-sm font-medium text-white">{a.name}</span>
									<p class="text-[10px] text-muted m-0 mt-0.5">{a.desc}</p>
								</div>
							</div>
							<span class="text-[10px] font-medium text-primary bg-primary/15 px-2 py-0.5 rounded-full shrink-0">{a.status}</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-[10px] text-primary bg-primary/10 px-2 py-0.5 rounded border border-primary/20">{a.type}</span>
							<span class="text-[10px] text-muted bg-surface px-2 py-0.5 rounded border border-border">{a.tag}</span>
						</div>
						<div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[10px]">
							<div class="flex items-center gap-1.5"><svg class="w-3 h-3 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/></svg><span class="text-muted">{a.questions} questions</span></div>
							<div class="flex items-center gap-1.5"><svg class="w-3 h-3 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg><span class="text-muted">{a.points} points</span></div>
							<div class="flex items-center gap-1.5"><svg class="w-3 h-3 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg><span class="text-muted">{a.date}</span></div>
							<div class="flex items-center gap-1.5"><svg class="w-3 h-3 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228M18.75 4.236V2.721"/></svg><span class="text-muted">Best: {a.best}</span></div>
						</div>
						<div class="flex items-center justify-between text-[10px] text-muted border-t border-border pt-2">
							<span>{a.attempts} {assAttempt}</span>
						</div>
						<div class="bg-surface border border-border rounded-lg py-2 flex items-center justify-center gap-1.5 text-xs text-white font-medium">
							<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
							{assPlay}
						</div>
					</div>
				))}
			</div>
		</div>
	</div>

	<!-- TAB: Analytics -->
	<div class="mockup-panel hidden flex-1 overflow-hidden flex-col" data-panel="analytics">
		<div class="px-6 py-5 border-b border-border">
			<h3 class="text-base font-semibold text-white m-0">{anaTitle}</h3>
			<p class="text-xs text-muted m-0 mt-1">{anaSub}</p>
		</div>
		<div class="px-6 py-5 flex-1 flex flex-col gap-4">
			<!-- Stats row -->
			<div class="grid grid-cols-4 gap-3">
				{[
					{ label: isDE ? 'Abgeschlossen' : 'Completed', value: '24', sub: isDE ? 'Assessments' : 'assessments' },
					{ label: isDE ? 'Durchschnitt' : 'Avg Score', value: '87%', sub: isDE ? 'Aller Quizzes' : 'across quizzes' },
					{ label: isDE ? 'Lernzeit' : 'Study Time', value: '48h', sub: isDE ? 'Diese Woche' : 'this month' },
					{ label: isDE ? 'Streak' : 'Streak', value: '12', sub: isDE ? 'Tage' : 'days' },
				].map((stat) => (
					<div class="bg-surface border border-border rounded-lg p-3 text-center">
						<div class="text-lg font-bold text-white">{stat.value}</div>
						<div class="text-[10px] text-muted mt-0.5">{stat.label}</div>
					</div>
				))}
			</div>

			<!-- Progress bars -->
			<div class="bg-surface border border-border rounded-xl p-4 flex flex-col gap-3">
				<span class="text-xs font-medium text-white">{isDE ? 'Fortschritt nach Modul' : 'Progress by Module'}</span>
				{[
					{ label: isDE ? 'Rechnungswesen' : 'Accounting', pct: 92 },
					{ label: isDE ? 'Wirtschaftsrecht' : 'Business Law', pct: 74 },
					{ label: isDE ? 'Büroprozesse' : 'Office Processes', pct: 58 },
					{ label: isDE ? 'Kundenberatung' : 'Customer Advisory', pct: 41 },
				].map((mod) => (
					<div class="flex flex-col gap-1">
						<div class="flex justify-between text-[10px]">
							<span class="text-muted">{mod.label}</span>
							<span class="text-white font-medium">{mod.pct}%</span>
						</div>
						<div class="h-1.5 bg-border rounded-full overflow-hidden">
							<div class="h-full bg-primary rounded-full" style={`width: ${mod.pct}%`}></div>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</div>

<style>
	.mockup-nav-tab {
		@apply text-[10px] md:text-xs text-muted px-2 py-1 rounded-md bg-transparent border-none cursor-pointer font-sans transition-colors duration-150 hover:text-white flex items-center gap-1.5;
	}
	.mockup-nav-active {
		@apply bg-primary/15 text-primary;
	}
	.mockup-pill {
		@apply text-[10px] text-muted px-3 py-1.5 rounded-lg border border-border bg-surface;
	}
	.mockup-pill-active {
		@apply border-primary/30 text-primary bg-primary/10;
	}
	.mockup-filter-pill {
		@apply text-[10px] text-muted px-3 py-1.5 rounded-lg border border-border bg-surface;
	}
</style>

<script>
	function initMockupTabs() {
		const tabs = document.querySelectorAll('.mockup-nav-tab[data-tab]');
		const panels = document.querySelectorAll('.mockup-panel');

		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				const target = tab.getAttribute('data-tab');

				// Update tabs
				tabs.forEach(t => t.classList.remove('mockup-nav-active'));
				tab.classList.add('mockup-nav-active');

				// Update panels
				panels.forEach(p => {
					if (p.getAttribute('data-panel') === target) {
						p.classList.remove('hidden');
						p.classList.add('flex');
					} else {
						p.classList.add('hidden');
						p.classList.remove('flex');
					}
				});
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initMockupTabs);
	document.addEventListener('astro:page-load', initMockupTabs);
</script>

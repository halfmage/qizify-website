---
interface Props {
	buttonLabel?: string;
	copiedLabel?: string;
}

const {
	buttonLabel = 'Vorlage kopieren',
	copiedLabel = 'Kopiert!'
} = Astro.props;
---

<div class="copy-block" data-copy-block>
	<button type="button" class="copy-block-btn" data-copy-btn data-copied-label={copiedLabel} aria-label={buttonLabel}>
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
		</svg>
		<span data-copy-label>{buttonLabel}</span>
	</button>
	<div class="copy-block-content" data-copy-content>
		<slot />
	</div>
</div>

<style>
	.copy-block {
		position: relative;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 0.75rem;
		padding: 3rem 1.5rem 1.5rem 1.5rem;
		margin: 2rem 0;
		background: rgba(255, 255, 255, 0.02);
	}
	.copy-block-btn {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.75rem;
		font-size: 0.8125rem;
		font-weight: 500;
		line-height: 1;
		color: rgba(255, 255, 255, 0.9);
		background: rgba(123, 92, 236, 0.9);
		border: 1px solid rgba(123, 92, 236, 0.6);
		border-radius: 0.5rem;
		cursor: pointer;
		transition: background 150ms ease, color 150ms ease;
		z-index: 2;
	}
	.copy-block-btn:hover {
		background: rgba(123, 92, 236, 1);
		color: #fff;
	}
	.copy-block-btn:focus-visible {
		outline: 2px solid #fff;
		outline-offset: 2px;
	}
	.copy-block-btn[data-copied="true"] {
		background: rgba(52, 211, 153, 0.95);
		border-color: rgba(52, 211, 153, 0.7);
		color: #0a0a0b;
	}
	.copy-block-content :global(:first-child) {
		margin-top: 0 !important;
	}
	.copy-block-content :global(:last-child) {
		margin-bottom: 0 !important;
	}
	/* Override Tailwind Typography (prose) styles inside the template so it
	   reads as a unified document rather than separate bordered sections. */
	.copy-block-content :global(h3) {
		margin-top: 0 !important;
		margin-bottom: 1.25rem !important;
		padding-bottom: 0.75rem;
		font-size: 1.25rem;
		line-height: 1.3;
		text-align: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.15);
	}
	.copy-block-content :global(h4) {
		margin-top: 1.5rem !important;
		margin-bottom: 0.5rem !important;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.35;
		color: #fff;
	}
	.copy-block-content :global(h4:first-of-type) {
		margin-top: 0.5rem !important;
	}
	.copy-block-content :global(p) {
		margin-top: 0 !important;
		margin-bottom: 0.75rem !important;
		line-height: 1.55 !important;
		font-size: 0.95rem;
	}
	.copy-block-content :global(table) {
		margin-top: 0.5rem !important;
		margin-bottom: 0 !important;
		font-size: 0.875rem;
		width: 100%;
		border-collapse: collapse;
	}
	.copy-block-content :global(th),
	.copy-block-content :global(td) {
		padding: 0.4rem 0.6rem !important;
		vertical-align: top;
		line-height: 1.4;
	}
	.copy-block-content :global(ul) {
		margin-top: 0.25rem !important;
		margin-bottom: 0.5rem !important;
		padding-left: 1.25rem !important;
	}
	.copy-block-content :global(ul li) {
		margin: 0.2rem 0 !important;
	}
</style>

<script is:inline data-astro-rerun>
	(function() {
		document.querySelectorAll('[data-copy-block]').forEach(function(block) {
			if (block.dataset.copyBound === 'true') return;
			block.dataset.copyBound = 'true';
			var btn = block.querySelector('[data-copy-btn]');
			var label = block.querySelector('[data-copy-label]');
			var content = block.querySelector('[data-copy-content]');
			if (!btn || !label || !content) return;
			var originalText = label.textContent;
			var copiedText = btn.getAttribute('data-copied-label') || 'Kopiert!';

			// Build a clean HTML payload: clone the content, strip Astro-internal
			// attributes and the button, and wrap tables with minimal attributes
			// so Word renders them as real tables with visible grid lines.
			function buildRichPayload() {
				var clone = content.cloneNode(true);
				clone.querySelectorAll('*').forEach(function(el) {
					for (var i = el.attributes.length - 1; i >= 0; i--) {
						var name = el.attributes[i].name;
						if (name.indexOf('data-astro-') === 0 || name === 'data-copy-content') {
							el.removeAttribute(name);
						}
					}
				});
				clone.querySelectorAll('table').forEach(function(t) {
					t.setAttribute('border', '1');
					t.setAttribute('cellspacing', '0');
					t.setAttribute('cellpadding', '6');
					t.style.borderCollapse = 'collapse';
				});
				clone.querySelectorAll('th, td').forEach(function(c) {
					c.style.border = '1px solid #999';
					c.style.padding = '6px 8px';
					c.style.verticalAlign = 'top';
				});
				var html = '<meta charset="utf-8">' + clone.innerHTML;
				var text = content.innerText || content.textContent || '';
				return { html: html, text: text };
			}

			function copyRich(payload) {
				// 1) Modern: ClipboardItem with both HTML + plain text
				if (window.ClipboardItem && navigator.clipboard && navigator.clipboard.write) {
					try {
						var item = new ClipboardItem({
							'text/html': new Blob([payload.html], { type: 'text/html' }),
							'text/plain': new Blob([payload.text], { type: 'text/plain' })
						});
						return navigator.clipboard.write([item]);
					} catch (e) { /* fall through */ }
				}
				// 2) Fallback: render HTML into a hidden contenteditable, select it,
				// and use execCommand('copy'). Preserves formatting in older browsers.
				return new Promise(function(resolve, reject) {
					try {
						var container = document.createElement('div');
						container.setAttribute('contenteditable', 'true');
						container.style.position = 'fixed';
						container.style.left = '-9999px';
						container.style.top = '0';
						container.style.opacity = '0';
						container.innerHTML = payload.html;
						document.body.appendChild(container);
						var range = document.createRange();
						range.selectNodeContents(container);
						var sel = window.getSelection();
						sel.removeAllRanges();
						sel.addRange(range);
						var ok = document.execCommand('copy');
						sel.removeAllRanges();
						document.body.removeChild(container);
						if (ok) { resolve(); } else { reject(new Error('execCommand copy failed')); }
					} catch (e) { reject(e); }
				});
			}

			btn.addEventListener('click', function() {
				var payload = buildRichPayload();
				copyRich(payload).then(function() {
					label.textContent = copiedText;
					btn.setAttribute('data-copied', 'true');
					setTimeout(function() {
						label.textContent = originalText;
						btn.removeAttribute('data-copied');
					}, 2000);
				}).catch(function(err) {
					console.error('Rich copy failed, falling back to plain text:', err);
					if (navigator.clipboard && navigator.clipboard.writeText) {
						navigator.clipboard.writeText(payload.text).then(function() {
							label.textContent = copiedText;
							btn.setAttribute('data-copied', 'true');
							setTimeout(function() {
								label.textContent = originalText;
								btn.removeAttribute('data-copied');
							}, 2000);
						});
					}
				});
			});
		});
	})();
</script>

---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	lang: 'en' | 'de';
	currentPath: string;
	ogImage?: string;
	breadcrumbTitle?: string;
	heroImage?: string;
}

const { title, description, lang, currentPath, ogImage = '/opengraph-image.jpg', breadcrumbTitle, heroImage } = Astro.props;

import { getAlternatePath } from '../utils/i18n';
import { SITE } from '../utils/page-pairs.mjs';

// Construct full URLs
const siteUrl = SITE;
const currentUrl = `${siteUrl}${currentPath}`;
const enPath = lang === 'en' ? currentPath : getAlternatePath(currentPath, 'de');
const dePath = lang === 'de' ? currentPath : getAlternatePath(currentPath, 'en');
const ogImageUrl = `${siteUrl}${ogImage}`;

// Structured data for Organization (merged with aggregate rating)
const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'LearnSlice',
	url: siteUrl,
	logo: `${siteUrl}/images/learnslice-logo.svg`,
	description: lang === 'en'
		? 'AI-powered learning platform for apprenticeships. Automate mentoring and save money with LearnSlice.'
		: 'KI-gestützte Lernplattform für Ausbildungen. Automatisieren Sie Mentoring und sparen Sie Geld mit LearnSlice.',
	sameAs: [
		'https://www.linkedin.com/company/49113282',
		'https://www.instagram.com/learnslice',
	],
	contactPoint: {
		'@type': 'ContactPoint',
		contactType: 'Customer Service',
		email: 'info@learnslice.com',
	},
	address: {
		'@type': 'PostalAddress',
		addressCountry: 'DE',
	},
};

// Structured data for SoftwareApplication
const softwareSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'LearnSlice',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Web',
	description: lang === 'en'
		? 'AI-powered learning platform for German apprenticeships. Combines IHK exam preparation with company-specific knowledge into personalized learning paths with 24/7 AI coaching.'
		: 'KI-gestützte Lernplattform für die Berufsausbildung. Verbindet IHK-Prüfungsvorbereitung mit unternehmensspezifischem Wissen zu personalisierten Lernpfaden mit 24/7 KI-Coaching.',
	url: siteUrl,
};

// Structured data for WebSite (enables sitelinks search box in Google)
const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'LearnSlice',
	alternateName: lang === 'de' ? 'LearnSlice - KI-Ausbildungsplattform' : 'LearnSlice - AI Apprenticeship Training',
	url: siteUrl,
	inLanguage: lang === 'de' ? 'de-DE' : 'en-US',
	publisher: {
		'@type': 'Organization',
		name: 'LearnSlice',
		url: siteUrl,
	},
};

// Breadcrumb schema
const segmentLabels: Record<string, Record<string, string>> = {
	en: {
		blog: 'Blog',
		research: 'Research & Evidence',
		companies: 'For Companies',
		schools: 'For Schools',
		agencies: 'For Agencies',
		'apprenticeship-savings-calculator': 'Savings Calculator',
		'learnslice-vs-traditional-training': 'LearnSlice vs. Traditional Training',
		'learnslice-vs-video-ihk-tools': 'LearnSlice vs. Video IHK Tools',
		'learnslice-vs-publisher-lms': 'LearnSlice vs. Publisher / Enterprise LMS',
		'learnslice-vs-animated-video-platforms': 'LearnSlice vs. Animated-Video Platforms',
		privacy: 'Privacy Policy',
		terms: 'Terms of Use',
		imprint: 'Imprint',
	},
	de: {
		blog: 'Blog',
		forschung: 'Forschung & Evidenz',
		companies: 'Für Unternehmen',
		schools: 'Für Schulen',
		agencies: 'Für Agenturen',
		'ausbildungskosten-rechner': 'Ausbildungskosten-Rechner',
		'learnslice-vs-traditionelle-ausbildung': 'LearnSlice vs. Traditionelle Ausbildung',
		'learnslice-vs-video-ihk-tools': 'LearnSlice vs. Video-IHK-Tools',
		'learnslice-vs-verlags-lms': 'LearnSlice vs. Verlags-LMS',
		'learnslice-vs-animations-lernplattformen': 'LearnSlice vs. Animations-Lernplattformen',
		privacy: 'Datenschutz',
		terms: 'AGB',
		imprint: 'Impressum',
	},
};

const homeName = lang === 'en' ? 'Home' : 'Startseite';
const homeUrl = lang === 'en' ? '/' : '/de';
const pathForBreadcrumbs = lang === 'de' ? currentPath.replace(/^\/de\/?/, '') : currentPath.replace(/^\//, '');
const segments = pathForBreadcrumbs.split('/').filter(Boolean);

const breadcrumbItems = [
	{ '@type': 'ListItem', position: 1, name: homeName, item: `${siteUrl}${homeUrl}` },
];

let cumulativePath = homeUrl === '/' ? '' : '/de';
for (let i = 0; i < segments.length; i++) {
	cumulativePath += `/${segments[i]}`;
	const isLast = i === segments.length - 1;
	const label = isLast && breadcrumbTitle
		? breadcrumbTitle
		: segmentLabels[lang]?.[segments[i]] || segments[i].replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
	breadcrumbItems.push({
		'@type': 'ListItem',
		position: i + 2,
		name: label,
		item: `${siteUrl}${cumulativePath}`,
	});
}

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems,
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#2a2622" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

		<!-- Preconnect to external resources -->
		<link rel="preconnect" href="https://rsms.me" crossorigin />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Fonts: Inter Variable (clean geometric sans) + JetBrains Mono (monospace) -->
		<link href="https://rsms.me/inter/inter.css" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content={lang === 'en'
			? 'AI learning platform, apprenticeship training, mentoring, mentoring automation, digital mentoring, vocational training, German SMEs'
			: 'KI-Lernplattform, Ausbildungsplattform, Aus- und Weiterbildung, Ausbildungs-Automatisierung, Berufsausbildung, Ausbildung, deutsche KMU, digitales Mentoring, digitales Lernen'} />
		<meta name="author" content="LearnSlice" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />
		<meta property="og:site_name" content="LearnSlice" />
		<meta property="og:locale" content={lang === 'en' ? 'en_US' : 'de_DE'} />
		{enPath && dePath && (
			<meta property="og:locale:alternate" content={lang === 'en' ? 'de_DE' : 'en_US'} />
		)}

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={currentUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={title} />
		<meta name="twitter:creator" content="@learnslice" />
		<meta name="twitter:site" content="@learnslice" />

		<!-- Preload hero LCP image (homepages only) -->
		{heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}

		<!-- Canonical URL -->
		<link rel="canonical" href={currentUrl} />

		<!-- Hreflang Tags (omitted on solo-language pages). x-default points to the
		     German version: DACH is the primary market. -->
		{enPath && dePath && (
			<>
				<link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
				<link rel="alternate" hreflang="de" href={`${siteUrl}${dePath}`} />
				<link rel="alternate" hreflang="x-default" href={`${siteUrl}${dePath}`} />
			</>
		)}

		<!-- Sitemap -->
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

		<!-- 100% privacy-first analytics -->
		<script is:inline>window.sa_event=window.sa_event||function(){var a=[].slice.call(arguments);window.sa_event.q?window.sa_event.q.push(a):window.sa_event.q=[a]};</script>
		<script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
	</head>
	<body>
		<a href="#main-content" class="skip-to-main">
			{lang === 'en' ? 'Skip to main content' : 'Zum Hauptinhalt springen'}
		</a>
		<main id="main-content">
			<slot />
		</main>
	</body>
</html>

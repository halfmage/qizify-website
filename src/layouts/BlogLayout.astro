---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import BlogCard from '../components/BlogCard.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import enContent from '../content/en.json';
import deContent from '../content/de.json';

interface Props {
	title: string;
	description: string;
	lang: 'en' | 'de';
	publishDate: Date;
	updatedDate?: Date;
	author: string;
	tags: string[];
	slug: string;
	ogImage?: string;
	keyTakeaways?: string[];
	faq?: { q: string; a: string }[];
}

const { title, description, lang, publishDate, updatedDate, author, tags, slug, ogImage, keyTakeaways, faq } = Astro.props;

const content = lang === 'en' ? enContent : deContent;
const basePath = lang === 'de' ? '/de' : '';
const currentPath = `${basePath}/blog/${slug}`;
const blogIndexPath = `${basePath}/blog`;
const backLabel = lang === 'en' ? 'Back to Blog' : 'Zur\u00FCck zum Blog';

const formattedDate = publishDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString(lang === 'en' ? 'en-US' : 'de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const blogOgImage = ogImage || '/opengraph-image.jpg';

const allPosts = await getCollection('blog');
const ownTags = new Set(tags);

const scoredPosts = allPosts
	.filter(p => p.data.lang === lang && p.slug !== slug)
	.map(p => ({
		post: p,
		score: p.data.tags.filter(t => ownTags.has(t)).length,
		date: new Date(p.data.publishDate).getTime(),
	}))
	.sort((a, b) => b.score - a.score || b.date - a.date);

const relatedPosts = scoredPosts.slice(0, 3).map(s => s.post);

const relatedHeading = lang === 'en' ? 'More on this topic' : 'Mehr zum Thema';
const takeawaysHeading = lang === 'en' ? 'Key Takeaways' : 'Auf einen Blick';
const faqHeading = lang === 'en' ? 'Frequently Asked Questions' : 'Häufig gestellte Fragen';
const tocLabel = lang === 'en' ? 'On this page' : 'Auf dieser Seite';
const sidebarCtaTitle = lang === 'en' ? 'See it on your occupation' : 'An Ihrem Beruf sehen';
const sidebarCtaSub = lang === 'en' ? '30-min demo, no pitch.' : '30-Min-Demo, kein Pitch.';
const sidebarCtaButton = lang === 'en' ? 'Get demo access' : 'Demo-Zugang erhalten';

const faqPageSchema = faq && faq.length > 0 ? {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map(({ q, a }) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: {
			'@type': 'Answer',
			text: a,
		},
	})),
} : null;

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: description,
	image: `https://learnslice.com${blogOgImage}`,
	datePublished: publishDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: author === 'LearnSlice Team'
		? {
			'@type': 'Organization',
			name: 'LearnSlice',
			url: 'https://learnslice.com',
			sameAs: [
				'https://www.linkedin.com/company/49113282',
				'https://www.instagram.com/learnslice',
			],
		}
		: {
			'@type': 'Person',
			name: author,
			jobTitle: 'Junior Content Manager',
			worksFor: {
				'@type': 'Organization',
				name: 'LearnSlice',
				url: 'https://learnslice.com',
			},
		},
	publisher: {
		'@type': 'Organization',
		name: 'LearnSlice',
		url: 'https://learnslice.com',
		logo: {
			'@type': 'ImageObject',
			url: 'https://learnslice.com/images/learnslice-logo.svg',
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': `https://learnslice.com${currentPath}`,
	},
};
---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	currentPath={currentPath}
	breadcrumbTitle={title}
	ogImage={ogImage}
>
	<Header
		logo={content.nav.logo}
		menu={content.nav.menu}
		cta={content.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<article class="py-20 md:py-28 px-6 md:px-8 pt-32">
		<div class="max-w-2xl lg:max-w-6xl mx-auto lg:grid lg:grid-cols-[minmax(0,46rem)_15rem] lg:justify-center lg:gap-16">
		<div class="min-w-0">
			<!-- Back link -->
			<a
				href={blogIndexPath}
				class="inline-flex items-center gap-2 text-muted hover:text-white transition-colors text-sm mb-10"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="19" y1="12" x2="5" y2="12"></line>
					<polyline points="12 19 5 12 12 5"></polyline>
				</svg>
				{backLabel}
			</a>

			<!-- Article header -->
			<header class="mb-12">
				{tags.length > 0 && (
					<div class="flex flex-wrap gap-2 mb-4">
						{tags.map(tag => (
							<span class="section-label">{tag}</span>
						))}
					</div>
				)}

				<h1 class="text-display-sm md:text-display text-white mb-6">
					{title}
				</h1>

				<div class="flex items-center gap-3 text-muted text-sm font-mono">
					<span>{author}</span>
					<span class="text-border-light">/</span>
					<time datetime={publishDate.toISOString()}>{formattedDate}</time>
					{formattedUpdatedDate && (
						<>
							<span class="text-border-light">/</span>
							<span>{lang === 'en' ? 'Updated' : 'Aktualisiert'} {formattedUpdatedDate}</span>
						</>
					)}
				</div>
			</header>

			{keyTakeaways && keyTakeaways.length > 0 && (
				<aside class="mb-12 bg-surface border border-border rounded-lg p-6 md:p-8" aria-labelledby="key-takeaways-heading">
					<h2 id="key-takeaways-heading" class="text-xs font-mono uppercase tracking-widest text-primary mb-4">
						{takeawaysHeading}
					</h2>
					<ul class="space-y-2 list-disc list-outside pl-5 text-white/90 leading-relaxed marker:text-primary">
						{keyTakeaways.map(item => <li>{item}</li>)}
					</ul>
				</aside>
			)}

			<!-- Article content -->
			<div class="prose prose-invert prose-lg
				prose-headings:tracking-tight
				prose-h2:font-bold prose-h2:mt-16 prose-h2:mb-6
				prose-h3:font-bold prose-h3:mt-10 prose-h3:mb-4
				prose-p:mb-6 prose-p:leading-8
				prose-a:text-primary prose-a:no-underline hover:prose-a:underline
				prose-strong:text-white
				prose-li:marker:text-primary
				prose-blockquote:border-primary/30 prose-blockquote:not-italic
				prose-code:text-primary prose-code:bg-primary/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:text-sm
				prose-pre:bg-surface prose-pre:border prose-pre:border-border prose-pre:rounded-lg
				prose-hr:border-border
				prose-img:rounded-xl prose-img:border prose-img:border-border
			">
				<slot />
			</div>
		<!-- Author bio -->
			<div class="mt-16 pt-8 border-t border-border">
				<p class="text-xs font-mono uppercase tracking-widest text-muted mb-3">
					{lang === 'en' ? 'Written by' : 'Geschrieben von'}
				</p>
				<div class="flex items-center gap-4">
					<div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold text-sm">
						{author.charAt(0)}
					</div>
					<div>
						<p class="text-white font-semibold text-sm m-0">{author}</p>
						{author !== 'LearnSlice Team' && (
							<p class="text-muted text-xs m-0">
								{lang === 'en' ? 'Junior Content Manager, LearnSlice' : 'Junior Content Manager, LearnSlice'}
							</p>
						)}
					</div>
				</div>
			</div>
		</div>

			<!-- On-this-page sidebar (large screens only). The CTA is always rendered so
			     the column is never empty, even on short posts or when the TOC is absent. -->
			<aside class="hidden lg:block">
				<div class="sticky top-28">
					<div id="toc-wrap" class="mb-8" hidden>
						<p class="text-xs font-mono uppercase tracking-widest text-muted mb-4">{tocLabel}</p>
						<nav id="toc" aria-label={tocLabel} class="flex flex-col border-l border-border text-sm"></nav>
					</div>
					<a
						href="#demo-request"
						data-modal-trigger="demo-request"
						class="group block rounded-lg border border-border bg-surface p-5 hover:border-primary/40 transition-colors"
					>
						<p class="text-white font-semibold text-sm mb-1">{sidebarCtaTitle}</p>
						<p class="text-muted text-xs mb-3 leading-relaxed">{sidebarCtaSub}</p>
						<span class="inline-flex items-center gap-1 text-primary text-sm font-medium">
							{sidebarCtaButton}
							<span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
						</span>
					</a>
				</div>
			</aside>
		</div>
	</article>

	{faq && faq.length > 0 && (
		<section class="py-12 md:py-16 px-6 md:px-8 border-t border-border" aria-labelledby="faq-heading">
			<div class="max-w-2xl mx-auto">
				<h2 id="faq-heading" class="text-heading text-white mb-8 md:mb-10">{faqHeading}</h2>
				<dl class="flex flex-col gap-8">
					{faq.map(({ q, a }) => (
						<div>
							<dt>
								<h3 class="text-lg font-semibold text-white mb-3 leading-snug">{q}</h3>
							</dt>
							<dd class="text-white/80 leading-relaxed m-0">{a}</dd>
						</div>
					))}
				</dl>
			</div>
		</section>
	)}

	{relatedPosts.length > 0 && (
		<section class="py-12 md:py-16 px-6 md:px-8 border-t border-border" aria-labelledby="related-posts-heading">
			<div class="max-w-4xl mx-auto">
				<h2 id="related-posts-heading" class="text-heading text-white mb-8 md:mb-10">{relatedHeading}</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{relatedPosts.map(post => (
						<BlogCard
							title={post.data.title}
							description={post.data.description}
							publishDate={post.data.publishDate}
							tags={post.data.tags}
							slug={post.slug}
							lang={lang}
						/>
					))}
				</div>
			</div>
		</section>
	)}

	<CTAFooter
		headline={content.cta.headline}
		subheadline={content.cta.subheadline}
		button={content.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={content.footer.privacyLabel}
		termsLabel={content.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />

	<script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema).replace(/<\/script/gi, '<\\/script')} />
	{faqPageSchema && (
		<script type="application/ld+json" set:html={JSON.stringify(faqPageSchema).replace(/<\/script/gi, '<\\/script')} />
	)}

	<style is:global>
		html { scroll-behavior: smooth; }
		@media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
	</style>

	<script>
		let tocObserver = null;

		function initBlogToc() {
			// Re-initialised on view-transition navigations: drop the old observer first.
			if (tocObserver) { tocObserver.disconnect(); tocObserver = null; }

			const article = document.querySelector('article .prose');
			const nav = document.getElementById('toc');
			const wrap = document.getElementById('toc-wrap');
			if (!article || !nav || !wrap) return;

			const headings = Array.from(article.querySelectorAll('h2'));
			// A table of contents only earns its space with a few sections.
			if (headings.length < 3) { nav.innerHTML = ''; wrap.hidden = true; return; }

			// Unicode-aware: keep letters/digits from any script (German umlauts, ß),
			// so the fallback never mangles an id if a heading ships without one.
			const slugify = (text) => {
				const s = text.toLowerCase().trim()
					.replace(/[^\p{L}\p{N}\s-]/gu, '')
					.replace(/\s+/g, '-')
					.replace(/-+/g, '-')
					.replace(/^-+|-+$/g, '');
				return s || 'section';
			};

			nav.innerHTML = '';
			const linkById = {};
			const used = new Set();

			headings.forEach((h) => {
				if (!h.id) {
					let base = slugify(h.textContent || '');
					let id = base, i = 2;
					while (used.has(id) || document.getElementById(id)) { id = `${base}-${i++}`; }
					h.id = id;
				}
				used.add(h.id);
				h.style.scrollMarginTop = '7rem';

				const a = document.createElement('a');
				a.href = '#' + h.id;
				a.textContent = h.textContent;
				a.className = 'block -ml-px border-l-2 border-transparent pl-4 py-1 text-muted hover:text-white leading-snug transition-colors';
				nav.appendChild(a);
				linkById[h.id] = a;
			});

			wrap.hidden = false;

			let active = null;
			const setActive = (id) => {
				const link = linkById[id];
				if (!link || link === active) return;
				if (active) active.classList.remove('text-white', 'border-primary');
				active = link;
				active.classList.add('text-white', 'border-primary');
			};

			tocObserver = new IntersectionObserver((entries) => {
				const visible = entries.filter((e) => e.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
				if (visible.length) setActive(visible[0].target.id);
			}, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

			headings.forEach((h) => tocObserver.observe(h));
		}

		if (document.readyState !== 'loading') initBlogToc();
		else document.addEventListener('DOMContentLoaded', initBlogToc);
		document.addEventListener('astro:page-load', initBlogToc);
	</script>
</BaseLayout>

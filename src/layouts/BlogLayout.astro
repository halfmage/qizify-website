---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import enContent from '../content/en.json';
import deContent from '../content/de.json';

interface Props {
	title: string;
	description: string;
	lang: 'en' | 'de';
	publishDate: Date;
	updatedDate?: Date;
	author: string;
	tags: string[];
	slug: string;
	ogImage?: string;
}

const { title, description, lang, publishDate, updatedDate, author, tags, slug, ogImage } = Astro.props;

const content = lang === 'en' ? enContent : deContent;
const basePath = lang === 'de' ? '/de' : '';
const currentPath = `${basePath}/blog/${slug}`;
const blogIndexPath = `${basePath}/blog`;
const backLabel = lang === 'en' ? 'Back to Blog' : 'Zur\u00FCck zum Blog';

const formattedDate = publishDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString(lang === 'en' ? 'en-US' : 'de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const blogOgImage = ogImage || '/opengraph-image.jpg';

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: description,
	image: `https://learnslice.com${blogOgImage}`,
	datePublished: publishDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Organization',
		name: author,
		url: 'https://learnslice.com',
	},
	publisher: {
		'@type': 'Organization',
		name: 'LearnSlice',
		url: 'https://learnslice.com',
		logo: {
			'@type': 'ImageObject',
			url: 'https://learnslice.com/images/learnslice-logo.svg',
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': `https://learnslice.com${currentPath}`,
	},
};
---

<BaseLayout
	title={`${title} | LearnSlice Blog`}
	description={description}
	lang={lang}
	currentPath={currentPath}
	breadcrumbTitle={title}
	ogImage={ogImage}
>
	<Header
		logo={content.nav.logo}
		menu={content.nav.menu}
		cta={content.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<article class="py-20 md:py-32 px-6 md:px-8 pt-32">
		<div class="max-w-2xl mx-auto">
			<!-- Back link -->
			<a
				href={blogIndexPath}
				class="inline-flex items-center gap-2 text-muted hover:text-white transition-colors text-sm mb-10"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="19" y1="12" x2="5" y2="12"></line>
					<polyline points="12 19 5 12 12 5"></polyline>
				</svg>
				{backLabel}
			</a>

			<!-- Article header -->
			<header class="mb-12">
				{tags.length > 0 && (
					<div class="flex flex-wrap gap-2 mb-4">
						{tags.map(tag => (
							<span class="section-label">{tag}</span>
						))}
					</div>
				)}

				<h1 class="text-display-sm md:text-display text-white mb-6">
					{title}
				</h1>

				<div class="flex items-center gap-3 text-muted text-sm font-mono">
					<span>{author}</span>
					<span class="text-border-light">/</span>
					<time datetime={publishDate.toISOString()}>{formattedDate}</time>
					{formattedUpdatedDate && (
						<>
							<span class="text-border-light">/</span>
							<span>{lang === 'en' ? 'Updated' : 'Aktualisiert'} {formattedUpdatedDate}</span>
						</>
					)}
				</div>
			</header>

			<!-- Article content -->
			<div class="prose prose-invert prose-lg max-w-none
				prose-headings:text-white prose-headings:font-semibold prose-headings:tracking-tight
				prose-h2:text-heading prose-h2:mt-14 prose-h2:mb-6
				prose-h3:text-heading-sm prose-h3:mt-10 prose-h3:mb-4
				prose-p:text-white/70 prose-p:leading-relaxed prose-p:text-base
				prose-a:text-primary prose-a:no-underline hover:prose-a:underline
				prose-strong:text-white
				prose-ul:text-white/70 prose-ol:text-white/70
				prose-li:marker:text-primary
				prose-blockquote:border-primary/30 prose-blockquote:text-muted prose-blockquote:not-italic
				prose-code:text-primary prose-code:bg-primary/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:text-sm
				prose-pre:bg-surface prose-pre:border prose-pre:border-border prose-pre:rounded-lg
				prose-hr:border-border
				prose-table:border prose-table:border-border prose-table:rounded-lg prose-table:overflow-hidden
				prose-thead:bg-surface prose-thead:border-b prose-thead:border-border
				prose-th:text-white prose-th:font-semibold prose-th:text-sm prose-th:px-4 prose-th:py-3
				prose-td:text-white/70 prose-td:text-sm prose-td:px-4 prose-td:py-3 prose-td:border-t prose-td:border-border
				prose-img:rounded-xl prose-img:border prose-img:border-border
			">
				<slot />
			</div>
		</div>
	</article>

	<CTAFooter
		headline={content.cta.headline}
		subheadline={content.cta.subheadline}
		button={content.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={content.footer.privacyLabel}
		termsLabel={content.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />

	<script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
</BaseLayout>

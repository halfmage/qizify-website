---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import LogosSlider from '../components/LogosSlider.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import ConsultationModal from '../components/ConsultationModal.astro';
import LeadMagnetForm from '../components/LeadMagnetForm.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/training-providers';
const t = enContent.trainingProviders;
const s = enContent.solutions;

// Intrinsic dimensions of the use-case screenshots (prevent layout shift), in item order.
const ucDims = [
	{ w: 2890, h: 1516 },
	{ w: 2620, h: 1432 },
	{ w: 2912, h: 1570 },
	{ w: 1950, h: 1190 },
];
---

<BaseLayout
	title="Learning software for training providers: LMS, AI chatbot, rehab | LearnSlice"
	description="We build and run AI learning coaches, LMS, and learning platforms for training providers, retraining, and rehabilitation. Sovereign, accessible, and designed around your documentation duties. GDPR compliant and hosted in Germany."
	lang={lang}
	currentPath={currentPath}
	breadcrumbTitle="For Training Providers"
>
	<Header logo={enContent.nav.logo} menu={enContent.nav.menu} cta={t.hero.ctaPrimary} ctaModalTrigger="project-inquiry" currentLang={lang} currentPath={currentPath} />

	<!-- Hero: radial glow -->
	<section class="relative min-h-[70vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-8 md:py-12">
			<div class="max-w-2xl">
				<span class="section-label mb-5 block">{t.hero.label}</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">
					{t.hero.headline.split('\n').map((line, i, arr) => (
						<>{i > 0 && <br />}<span class={i === arr.length - 1 ? 'gradient-text-primary' : ''}>{line}</span></>
					))}
				</h1>
				<p class="text-lg text-muted mb-6 max-w-xl leading-relaxed">{t.hero.subheadline}</p>
				<div class="flex flex-wrap items-center gap-3 mb-3">
					<Button variant="primary" href="#project-inquiry" data-modal-trigger="project-inquiry" aria-label={t.hero.ctaPrimary}>{t.hero.ctaPrimary}</Button>
					<Button variant="secondary" href="#digitalcheck" aria-label={t.hero.ctaSecondary}>{t.hero.ctaSecondary}</Button>
				</div>
				<p class="text-sm text-muted mb-1.5">{t.hero.microcopy}</p>
				<p class="text-sm text-white/70 mb-6">{t.hero.riskReversal}</p>
				<div class="flex items-center gap-2.5 text-xs md:text-sm text-muted border-t border-white/10 pt-5 max-w-xl">
					<Icon name="hugeicons:security-check" class="w-4 h-4 text-primary shrink-0" />
					<span>{t.hero.trust}</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Above-the-fold proof: trusted-by logos -->
	<LogosSlider headline={s.trustedByLine} logos={enContent.trustedBy.logos} />

	<!-- Need / why now -->
	<ProblemStatement badge={t.problem.badge} headline={t.problem.headline} body={t.problem.body} />

	<!-- What we build for training providers -->
	<WhyChooseUs headline={t.build.headline} items={t.build.items} />

	<!-- Outcomes -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-12 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{t.outcomes.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">{t.outcomes.headline}</h2>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-border rounded-xl overflow-hidden">
				{t.outcomes.stats.map((stat) => (
					<div class="bg-surface px-4 py-7 md:px-6 md:py-8 text-center">
						<div class="text-base md:text-heading-sm font-semibold mb-2 leading-tight text-primary">{stat.value}</div>
						<div class="text-xs md:text-sm text-muted leading-snug">{stat.label}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Lead magnet: BFSG/AZAV digital check (low-friction capture) -->
	<LeadMagnetForm currentLang={lang} />

	<!-- Proof: selected work (from solutions) -->
	<section id="proof" class="py-14 md:py-24 px-6 md:px-8 border-t border-border/50 scroll-mt-24">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 md:mb-20 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{t.proof.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-4">{t.proof.headline}</h2>
				<p class="text-base text-muted leading-relaxed m-0">{t.proof.intro}</p>
			</div>
			<div class="flex flex-col gap-16 md:gap-24">
				{s.useCases.items.map((uc, i) => (
					<div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
						<div class={`relative ${i % 2 === 1 ? 'md:order-2' : ''}`}>
							<div class="absolute -inset-6 glow-aurora opacity-70 pointer-events-none" aria-hidden="true"></div>
							<div class="relative rounded-xl border border-border-light overflow-hidden shadow-2xl shadow-black/50">
								<img src={uc.image} alt={uc.imageAlt} loading="lazy" decoding="async" width={ucDims[i].w} height={ucDims[i].h} class="w-full h-auto block" />
							</div>
						</div>
						<div class={i % 2 === 1 ? 'md:order-1' : ''}>
							<span class="section-label mb-3 block">{uc.eyebrow}</span>
							<h3 class="text-heading md:text-display-sm text-white mb-4 mt-0">{uc.title}</h3>
							<p class="text-base text-muted leading-relaxed mb-6">{uc.body}</p>
							<ul class="flex flex-col gap-3 list-none p-0 m-0">
								{uc.bullets.map((b) => (
									<li class="flex items-start gap-3 text-sm md:text-base text-white/90">
										<Icon name="hugeicons:checkmark-circle-02" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
										<span>{b}</span>
									</li>
								))}
							</ul>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<Testimonials headline={s.social.headline} items={enContent.testimonials.items} currentLang={lang} />

	<!-- Sovereignty and GDPR (from solutions) -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{s.sovereignty.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">{s.sovereignty.headline}</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				{s.sovereignty.items.map((item, i) => (
					<div class={`card-hover-glow ${i % 2 === 0 ? 'card-hover-glow-primary' : 'card-hover-glow-accent'} bg-surface p-8 group hover:bg-[#403930] transition-colors duration-200`}>
						<div class={`w-11 h-11 rounded-lg flex items-center justify-center mb-4 ${i % 2 === 0 ? 'bg-primary/10' : 'bg-accent/10'} group-hover:scale-110 transition-transform duration-200`}>
							<Icon name={item.icon} class={`w-5 h-5 ${i % 2 === 0 ? 'text-primary' : 'text-accent'}`} />
						</div>
						<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Funding / packaging -->
	<section class="py-12 md:py-16 px-6 md:px-8">
		<div class="max-w-3xl mx-auto relative">
			<div class="absolute -inset-4 glow-aurora opacity-50 pointer-events-none" aria-hidden="true"></div>
			<div class="relative bg-surface border border-border rounded-2xl p-8 md:p-12 overflow-hidden">
				<span class="section-label mb-4 block">{t.funding.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-3">{t.funding.headline}</h2>
				<p class="text-base text-muted leading-relaxed m-0 mb-4">{t.funding.body}</p>
				<p class="text-sm text-white/55 m-0">{t.funding.note}</p>
			</div>
		</div>
	</section>

	<!-- Engagement models (from solutions) -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{s.engagement.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-4">{s.engagement.headline}</h2>
				<p class="text-base text-muted leading-relaxed m-0">{s.engagement.intro}</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border rounded-xl overflow-hidden">
				{s.engagement.items.map((item, i) => (
					<div class={`card-hover-glow ${i % 2 === 0 ? 'card-hover-glow-primary' : 'card-hover-glow-accent'} bg-surface p-7 group hover:bg-[#403930] transition-colors duration-200`}>
						<div class={`w-11 h-11 rounded-lg flex items-center justify-center mb-4 ${i % 2 === 0 ? 'bg-primary/10' : 'bg-accent/10'} group-hover:scale-110 transition-transform duration-200`}>
							<Icon name={item.icon} class={`w-5 h-5 ${i % 2 === 0 ? 'text-primary' : 'text-accent'}`} />
						</div>
						<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<FAQ headline={t.faq.headline} items={t.faq.items} />

	<CTAFooter headline={t.cta.headline} subheadline={t.cta.subheadline} button={t.cta.button} buttonHref="#project-inquiry" note={t.cta.note} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={enContent.footer.privacyLabel} termsLabel={enContent.footer.termsLabel} />

	<div class="md:hidden h-20" aria-hidden="true"></div>
	<a
		href="#project-inquiry"
		data-modal-trigger="project-inquiry"
		class="md:hidden fixed bottom-0 left-0 right-0 z-40 mx-3 mb-[max(0.75rem,env(safe-area-inset-bottom))] text-center bg-primary text-white px-4 py-3 rounded-lg font-medium text-sm shadow-2xl shadow-black/40 hover:bg-[#6a4ae0] transition-colors"
	>
		Book a strategy call
	</a>

	<ConsultationModal currentLang={lang} />
</BaseLayout>

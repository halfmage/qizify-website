---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LogosSlider from '../components/LogosSlider.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/schools';
---

<BaseLayout
	title="AI Learning Platform for Vocational Schools | LearnSlice"
	description="Increase apprenticeship transition rates by 15-25%, reduce dropouts by 30%, and save teachers 25% of their time with AI-powered exam preparation and personalized learning."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={enContent.nav.logo}
		menu={enContent.nav.menu}
		cta={enContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<!-- Hero -->
	<section class="py-16 md:py-24 px-4 md:px-8 bg-dark relative overflow-hidden">
		<div class="absolute inset-0 z-0">
			<img src="/images/hero/hero-background.webp" alt="" class="w-full h-full object-cover opacity-30" aria-hidden="true" />
			<div class="absolute inset-0 bg-gradient-to-b from-dark/40 via-dark/80 to-dark"></div>
		</div>
		<div class="max-w-container mx-auto relative z-10">
			<div class="max-w-3xl">
				<div class="inline-block px-4 py-2 bg-primary/20 border border-primary rounded-full text-white text-sm font-medium uppercase tracking-wider mb-6">
					For Vocational Schools
				</div>
				<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
					Better Exam Results.<br />Less Teacher Workload.
				</h1>
				<p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl leading-relaxed">
					LearnSlice gives your students personalized AI coaching aligned to IHK exam requirements. Automated exercises, real-time feedback, and adaptive learning paths — so teachers can focus on what matters.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="#demo-request" class="inline-flex items-center justify-center px-8 py-4 bg-white text-black font-semibold rounded-xl hover:bg-white/90 transition-colors">
						Request Demo
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Key metrics -->
	<section class="py-12 md:py-16 px-4 md:px-8 bg-dark border-t border-white/10">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">15-25%</div>
					<div class="text-white/70 text-sm">Higher transition into apprenticeships</div>
				</div>
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">30%</div>
					<div class="text-white/70 text-sm">Fewer first-year dropouts</div>
				</div>
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">25%</div>
					<div class="text-white/70 text-sm">Time saved for teachers</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Benefits -->
	<section class="py-12 md:py-20 px-4 md:px-8 bg-dark">
		<div class="max-w-container mx-auto">
			<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-10 md:mb-14 text-center">
				How LearnSlice Helps Vocational Schools
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
				<div class="bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8">
					<h3 class="text-lg md:text-xl font-bold text-white mb-3">IHK-Aligned Content</h3>
					<p class="text-white/70 text-sm leading-relaxed">Pre-built learning paths mapped to IHK exam requirements for each vocational profession. Students practice with exam-quality questions automatically generated by AI.</p>
				</div>
				<div class="bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8">
					<h3 class="text-lg md:text-xl font-bold text-white mb-3">24/7 AI Tutoring</h3>
					<p class="text-white/70 text-sm leading-relaxed">Students get personalized coaching outside classroom hours. The AI identifies knowledge gaps and creates targeted review exercises — no extra teacher effort required.</p>
				</div>
				<div class="bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8">
					<h3 class="text-lg md:text-xl font-bold text-white mb-3">Analytics Dashboard</h3>
					<p class="text-white/70 text-sm leading-relaxed">Track student progress at a glance. Identify at-risk students early, see class-wide performance trends, and generate reports — all automated.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider
		headline={enContent.trustedBy.headline}
		logos={enContent.trustedBy.logos}
	/>

	<Testimonials
		headline={enContent.testimonials.headline}
		items={enContent.testimonials.items}
		currentLang={lang}
	/>

	<WhyChooseUs
		headline={enContent.whyChooseUs.headline}
		items={enContent.whyChooseUs.items}
	/>

	<FAQ
		headline={enContent.faq.headline}
		items={enContent.faq.items}
	/>

	<LeadCapture currentLang={lang} />

	<CTAFooter
		headline={enContent.cta.headline}
		subheadline={enContent.cta.subheadline}
		button={enContent.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={enContent.footer.privacyLabel}
		termsLabel={enContent.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LogosSlider from '../components/LogosSlider.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/schools';
---

<BaseLayout
	title="AI Learning Platform for Vocational Schools | LearnSlice"
	description="Increase apprenticeship transition rates by 15-25%, reduce dropouts by 30%, and save teachers 25% of their time with AI-powered exam preparation and personalized learning."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={enContent.nav.logo}
		menu={enContent.nav.menu}
		cta={enContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<!-- Hero -->
	<section class="relative min-h-[75vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-12 md:py-16">
			<div class="max-w-[700px]">
				<span class="section-label mb-5 block">For Vocational Schools</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">
					Better Exam Results.<br />Less Teacher Workload.
				</h1>
				<p class="text-lg text-muted mb-8 max-w-[560px] leading-relaxed">
					LearnSlice gives your students personalized AI coaching aligned to IHK exam requirements. Automated exercises, real-time feedback, and adaptive learning paths.
				</p>
				<a href="#demo-request" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-[#6a4ae0] transition-colors">
					Request Demo
					<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>
		</div>
	</section>

	<!-- Key metrics -->
	<section class="py-16 px-6 md:px-8 border-t border-border">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">15-25%</div>
					<div class="text-muted text-xs">Higher transition into apprenticeships</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">30%</div>
					<div class="text-muted text-xs">Fewer first-year dropouts</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">25%</div>
					<div class="text-muted text-xs">Time saved for teachers</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Benefits -->
	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16">
				<span class="section-label mb-4 block">Benefits</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">How LearnSlice Helps Vocational Schools</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8 group hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">IHK-Aligned Content</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Pre-built learning paths mapped to IHK exam requirements for each vocational profession. Students practice with exam-quality questions automatically generated by AI.</p>
				</div>
				<div class="bg-surface p-8 group hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">24/7 AI Tutoring</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Students get personalized coaching outside classroom hours. The AI identifies knowledge gaps and creates targeted review exercises.</p>
				</div>
				<div class="bg-surface p-8 group hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">Analytics Dashboard</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Track student progress at a glance. Identify at-risk students early, see class-wide performance trends, and generate reports.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={enContent.trustedBy.headline} logos={enContent.trustedBy.logos} />
	<Testimonials headline={enContent.testimonials.headline} items={enContent.testimonials.items} currentLang={lang} />
	<WhyChooseUs headline={enContent.whyChooseUs.headline} items={enContent.whyChooseUs.items} />
	<FAQ headline={enContent.faq.headline} items={enContent.faq.items} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={enContent.cta.headline} subheadline={enContent.cta.subheadline} button={enContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={enContent.footer.privacyLabel} termsLabel={enContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

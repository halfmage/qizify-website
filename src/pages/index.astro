---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import LogosSlider from '../components/LogosSlider.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import SavingsComparison from '../components/SavingsComparison.astro';
import HowItWorks from '../components/HowItWorks.astro';
import LearningResults from '../components/LearningResults.astro';
import CompanySlider from '../components/CompanySlider.astro';
import Testimonials from '../components/Testimonials.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import VocationalProfessions from '../components/VocationalProfessions.astro';
import FAQ from '../components/FAQ.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/';
---

<BaseLayout 
	title="AI Apprenticeship Training | IHK Exam Prep | LearnSlice"
	description="AI platform that gets apprentices job-ready in 8 weeks: IHK exam prep, onboarding, and upskilling in one place. Save up to €15K per apprentice."
	lang={lang}
	currentPath={currentPath}
	heroImage="/images/hero/hero-background.webp"
>
	<Header
		logo={enContent.nav.logo}
		menu={enContent.nav.menu}
		cta={enContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>
	
	<Hero
		headline={enContent.hero.headline}
		subheadline={enContent.hero.subheadline}
		ctaPrimary={enContent.hero.ctaPrimary}
		ctaSecondary={enContent.hero.ctaSecondary}
		stats={enContent.hero.stats}
		currentLang={lang}
	/>
	
	<LogosSlider 
		headline={enContent.trustedBy.headline}
		logos={enContent.trustedBy.logos}
	/>
	
	<ProblemStatement
		badge={enContent.problem.badge}
		headline={enContent.problem.headline}
		body={enContent.problem.body}
	/>

	<SavingsComparison
		headline={enContent.savingsComparison.headline}
		without={enContent.savingsComparison.without}
		with={enContent.savingsComparison.with}
	/>
	
	<HowItWorks
		badge={enContent.howItWorks.badge}
		headline={enContent.howItWorks.headline}
		steps={enContent.howItWorks.steps}
		lang={lang}
	/>
	
	<LearningResults 
		badge={enContent.learningResults.badge}
		headline={enContent.learningResults.headline}
		features={enContent.learningResults.features}
		compliance={enContent.learningResults.compliance}
	/>
	
	<VocationalProfessions
		headline={enContent.vocationalProfessions.headline}
		items={enContent.vocationalProfessions.items}
	/>

	<CompanySlider
		headline={enContent.madeForCompany.headline}
		tabs={enContent.madeForCompany.tabs}
	/>

	<Testimonials
		headline={enContent.testimonials.headline}
		items={enContent.testimonials.items}
		currentLang={lang}
	/>

	<WhyChooseUs
		headline={enContent.whyChooseUs.headline}
		items={enContent.whyChooseUs.items}
	/>

	<FAQ
		headline={enContent.faq.headline}
		items={enContent.faq.items}
	/>

	<CTAFooter
		headline={enContent.homepageCta.headline}
		subheadline={enContent.homepageCta.subheadline}
		button={enContent.homepageCta.button}
		currentLang={lang}
	/>
	
	<Footer
		currentLang={lang}
		privacyLabel={enContent.footer.privacyLabel}
		termsLabel={enContent.footer.termsLabel}
	/>

	<div class="md:hidden h-20" aria-hidden="true"></div>

	<a
		href="#demo-request"
		class="md:hidden fixed bottom-0 left-0 right-0 z-40 mx-3 mb-[max(0.75rem,env(safe-area-inset-bottom))] text-center bg-primary text-white px-4 py-3 rounded-lg font-medium text-sm shadow-2xl shadow-black/40 hover:bg-[#6a4ae0] transition-colors"
	>
		Book My Free Demo
	</a>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>

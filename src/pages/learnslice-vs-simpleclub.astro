---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LogosSlider from '../components/LogosSlider.astro';
import Testimonials from '../components/Testimonials.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/learnslice-vs-simpleclub';
---

<BaseLayout
	title="LearnSlice vs. Simpleclub | Apprenticeship Training Comparison"
	description="Detailed comparison of LearnSlice and Simpleclub for vocational training. Compare AI coaching, IHK alignment, company knowledge integration, GDPR compliance, and pricing."
	lang={lang}
	currentPath={currentPath}
>
	<Header logo={enContent.nav.logo} menu={enContent.nav.menu} cta={enContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="pt-32 pb-16 md:pb-24 px-6 md:px-8">
		<div class="max-w-3xl mx-auto text-center">
			<span class="section-label mb-5 block">Comparison</span>
			<h1 class="text-display-sm md:text-display text-white mb-6">LearnSlice vs. Simpleclub</h1>
			<p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">Both platforms serve the German vocational training market &mdash; but they take fundamentally different approaches.</p>
		</div>
	</section>

	<!-- Overview cards -->
	<section class="py-12 px-6 md:px-8">
		<div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
			<div class="bg-surface p-8">
				<h3 class="text-base font-semibold text-white mb-3">Simpleclub</h3>
				<p class="text-sm text-muted leading-relaxed mb-4">A popular B2C/B2B learning platform with video-based content covering school subjects and vocational training topics.</p>
				<ul class="text-sm text-muted space-y-2">
					<li>Video-based learning content</li>
					<li>B2C origin, expanded to B2B</li>
					<li>Broad subject coverage</li>
					<li>Large user base</li>
				</ul>
			</div>
			<div class="bg-surface p-8 relative">
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(124, 92, 252, 1) 0%, transparent 60%);"></div>
				<h3 class="text-base font-semibold text-primary mb-3 relative">LearnSlice</h3>
				<p class="text-sm text-muted leading-relaxed mb-4 relative">A B2B AI-powered platform built for apprenticeship training. Combines IHK exam prep with company-specific knowledge through personalized AI coaching.</p>
				<ul class="text-sm text-white/70 space-y-2 relative">
					<li>AI coaching with personalized learning paths</li>
					<li>Built for B2B from day one</li>
					<li>Company knowledge integration via RAG</li>
					<li>IHK-exam-aligned assessments</li>
				</ul>
			</div>
		</div>
	</section>

	<!-- Feature comparison -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-4xl mx-auto">
			<div class="text-center mb-14"><span class="section-label mb-4 block">Features</span><h2 class="text-heading md:text-display-sm text-white m-0">Feature-by-Feature Comparison</h2></div>
			<div class="overflow-x-auto rounded-xl border border-border">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Feature</th>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Simpleclub</th>
							<th class="text-left text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3 bg-primary/5"><span class="text-primary">LearnSlice</span></th>
						</tr>
					</thead>
					<tbody class="text-sm">
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Learning approach</td><td class="text-muted p-4 border-b border-border">Video lessons + exercises</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">AI chat coaching + adaptive paths</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Personalization</td><td class="text-muted p-4 border-b border-border">Topic recommendations</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Full AI adaptation per learner</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Company knowledge</td><td class="text-muted p-4 border-b border-border">Not available</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Upload docs, AI learns them</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">IHK exam alignment</td><td class="text-muted p-4 border-b border-border">General coverage</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Mapped per profession & region</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Assessment types</td><td class="text-muted p-4 border-b border-border">Multiple choice</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Quizzes + case studies + deep dives</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">AI coaching</td><td class="text-muted p-4 border-b border-border">Limited AI features</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Full conversational AI tutor 24/7</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Trainer analytics</td><td class="text-muted p-4 border-b border-border">Basic reports</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Executive dashboards</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Data hosting</td><td class="text-muted p-4 border-b border-border">EU</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Germany only</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Target user</td><td class="text-muted p-4 border-b border-border">Students & apprentices (B2C)</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Companies (B2B)</td></tr>
						<tr><td class="text-white/70 p-4 font-medium">Onboarding</td><td class="text-muted p-4">Self-service</td><td class="text-white p-4 bg-primary/[0.03] font-medium">Dedicated setup + support</td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- When to choose -->
	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16"><span class="section-label mb-4 block">Decision</span><h2 class="text-heading md:text-display-sm text-white m-0">When to Choose What</h2></div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8">
					<h3 class="text-base font-semibold text-white mb-4">Choose Simpleclub if you...</h3>
					<ul class="text-sm text-muted space-y-3">
						<li>Need a self-study tool for individual apprentices</li>
						<li>Want broad educational content beyond vocational training</li>
						<li>Prefer video-based learning over text/chat</li>
						<li>Don't need company-specific knowledge integration</li>
					</ul>
				</div>
				<div class="bg-surface p-8 relative">
					<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(124, 92, 252, 1) 0%, transparent 60%);"></div>
					<h3 class="text-base font-semibold text-primary mb-4 relative">Choose LearnSlice if you...</h3>
					<ul class="text-sm text-white/70 space-y-3 relative">
						<li>Want to reduce training costs and trainer time measurably</li>
						<li>Need to integrate company-specific onboarding content</li>
						<li>Require IHK-exam-aligned learning paths per profession</li>
						<li>Want AI coaching that adapts to each apprentice</li>
						<li>Need data hosted exclusively in Germany</li>
						<li>Want executive analytics on training ROI</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={enContent.trustedBy.headline} logos={enContent.trustedBy.logos} />
	<Testimonials headline={enContent.testimonials.headline} items={enContent.testimonials.items} currentLang={lang} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={enContent.cta.headline} subheadline={enContent.cta.subheadline} button={enContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={enContent.footer.privacyLabel} termsLabel={enContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

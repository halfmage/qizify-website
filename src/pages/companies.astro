---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TrustBar from '../components/TrustBar.astro';
import LogosSlider from '../components/LogosSlider.astro';
import SavingsComparison from '../components/SavingsComparison.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/companies';
---

<BaseLayout
	title="AI Apprenticeship Training for Companies | LearnSlice"
	description="Cut apprentice onboarding from 6 months to 8 weeks. AI coaching + IHK exam prep + company knowledge in one platform. Save up to €15K per apprentice."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={enContent.nav.logo}
		menu={enContent.nav.menu}
		cta={enContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<!-- Hero -->
	<section class="relative min-h-[75vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-12 md:py-16">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
				<div class="max-w-[600px]">
					<span class="section-label mb-5 block">For Companies</span>
					<h1 class="text-display-sm md:text-display text-white mb-6">
						Apprentices Productive Faster. Trainers Visibly Relieved.
					</h1>
					<p class="text-lg text-muted mb-6 leading-relaxed">
						From IHK exam prep to onboarding to upskilling: LearnSlice covers the full training cycle with AI learning paths and your company knowledge. Save up to €15K per apprentice.
					</p>
					<p class="text-sm text-muted mb-8">
						Trusted by 30+ German companies.
					</p>
					<div class="flex flex-col sm:flex-row gap-3">
						<a href="#demo-request" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-[#6a4ae0] transition-colors">
							Book My Free Demo
							<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
						<a href="#savings" class="inline-flex items-center justify-center px-4 py-2 border border-border-light text-muted text-sm font-medium rounded-lg hover:text-white hover:border-white/30 transition-colors">
							See the ROI
						</a>
					</div>
					<a href="https://calendly.com/learnslice-team/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-muted hover:text-white mt-4 transition-colors">
						Or pick a 30-min slot directly
						<svg class="w-3.5 h-3.5 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
					</a>
				</div>

				<div class="relative max-w-lg lg:max-w-none mx-auto w-full">
					<img
						src="/images/screenshots/learnslice-copilot-02.jpg"
						alt="LearnSlice AI Co-Pilot generating a personalized learning path with structured modules and quiz cards"
						class="w-full h-auto rounded-xl border border-border-light shadow-2xl shadow-primary/10"
						loading="eager"
						width="1440"
						height="900"
					/>
					<figure class="mt-6 pl-4 border-l-2 border-primary/50">
						<blockquote class="text-sm text-white/90 italic m-0 leading-relaxed">
							"{enContent.testimonials.items[0].pullQuote}"
						</blockquote>
						<figcaption class="text-xs text-muted mt-2 not-italic">
							{enContent.testimonials.items[0].name} · {enContent.testimonials.items[0].company}
						</figcaption>
					</figure>
				</div>
			</div>

			<!-- Stats strip, moved into hero -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16 pt-10 border-t border-border/60">
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">65%</div>
					<div class="text-muted text-xs">Faster to productivity</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">&euro;15K</div>
					<div class="text-muted text-xs">Saved per apprentice</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">50%</div>
					<div class="text-muted text-xs">Less trainer time</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">15%</div>
					<div class="text-muted text-xs">Dropout rate (from 30%)</div>
				</div>
			</div>
		</div>
	</section>

	<div id="savings">
		<SavingsComparison
			headline={enContent.savingsComparison.headline}
			without={enContent.savingsComparison.without}
			with={enContent.savingsComparison.with}
		/>
	</div>

	<HowItWorks
		badge={enContent.howItWorks.badge}
		headline={enContent.howItWorks.headline}
		steps={enContent.howItWorks.steps}
		lang={lang}
	/>

	<TrustBar currentLang={lang} />

	<LogosSlider
		headline={enContent.trustedBy.headline}
		logos={enContent.trustedBy.logos}
	/>

	<Testimonials
		headline={enContent.testimonials.headline}
		items={enContent.testimonials.items}
		currentLang={lang}
	/>

	<WhyChooseUs
		headline={enContent.whyChooseUs.headline}
		items={enContent.whyChooseUs.items}
	/>

	<FAQ
		headline={enContent.faq.headline}
		items={enContent.faq.items}
	/>

	<LeadCapture currentLang={lang} />

	<CTAFooter
		headline={enContent.cta.headline}
		subheadline={enContent.cta.subheadline}
		button={enContent.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={enContent.footer.privacyLabel}
		termsLabel={enContent.footer.termsLabel}
	/>

	<div class="md:hidden h-20" aria-hidden="true"></div>

	<a
		href="#demo-request"
		class="md:hidden fixed bottom-0 left-0 right-0 z-40 mx-3 mb-[max(0.75rem,env(safe-area-inset-bottom))] text-center bg-primary text-white px-4 py-3 rounded-lg font-medium text-sm shadow-2xl shadow-black/40 hover:bg-[#6a4ae0] transition-colors"
	>
		Book My Free Demo
	</a>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>

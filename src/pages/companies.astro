---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LogosSlider from '../components/LogosSlider.astro';
import SavingsComparison from '../components/SavingsComparison.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/companies';
---

<BaseLayout
	title="AI-Powered Apprenticeship Training for Companies | LearnSlice"
	description="Reduce apprentice onboarding from 6 months to 8 weeks. Save up to €15K per apprentice with AI coaching, IHK exam prep, and company knowledge integration. Free up 50% of trainer time."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={enContent.nav.logo}
		menu={enContent.nav.menu}
		cta={enContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<!-- Hero -->
	<section class="relative min-h-[75vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-12 md:py-16">
			<div class="max-w-[700px]">
				<span class="section-label mb-5 block">For Companies</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">
					Turn Every Apprentice Into a Top Performer in 8 Weeks
				</h1>
				<p class="text-lg text-muted mb-8 max-w-[560px] leading-relaxed">
					AI learning paths that combine IHK exam prep with your company knowledge. Save up to €15K per apprentice and give your trainers 50% of their week back.
				</p>
				<div class="flex flex-col sm:flex-row gap-3">
					<a href="#demo-request" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-[#6a4ae0] transition-colors">
						Book My Free Demo
						<svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</a>
					<a href="#savings" class="inline-flex items-center justify-center px-4 py-2 border border-border-light text-muted text-sm font-medium rounded-lg hover:text-white hover:border-white/30 transition-colors">
						See the ROI
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Key metrics -->
	<section class="py-16 px-6 md:px-8 border-t border-border">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">65%</div>
					<div class="text-muted text-xs">Faster to productivity</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">&euro;15K</div>
					<div class="text-muted text-xs">Saved per apprentice</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">50%</div>
					<div class="text-muted text-xs">Less trainer time</div>
				</div>
				<div class="text-center">
					<div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">15%</div>
					<div class="text-muted text-xs">Dropout rate (from 30%)</div>
				</div>
			</div>
		</div>
	</section>

	<div id="savings">
		<SavingsComparison
			headline={enContent.savingsComparison.headline}
			without={enContent.savingsComparison.without}
			with={enContent.savingsComparison.with}
		/>
	</div>

	<HowItWorks
		badge={enContent.howItWorks.badge}
		headline={enContent.howItWorks.headline}
		steps={enContent.howItWorks.steps}
		lang={lang}
	/>

	<LogosSlider
		headline={enContent.trustedBy.headline}
		logos={enContent.trustedBy.logos}
	/>

	<Testimonials
		headline={enContent.testimonials.headline}
		items={enContent.testimonials.items}
		currentLang={lang}
	/>

	<WhyChooseUs
		headline={enContent.whyChooseUs.headline}
		items={enContent.whyChooseUs.items}
	/>

	<FAQ
		headline={enContent.faq.headline}
		items={enContent.faq.items}
	/>

	<LeadCapture currentLang={lang} />

	<CTAFooter
		headline={enContent.cta.headline}
		subheadline={enContent.cta.subheadline}
		button={enContent.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={enContent.footer.privacyLabel}
		termsLabel={enContent.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>

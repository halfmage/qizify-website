---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LogosSlider from '../components/LogosSlider.astro';
import Testimonials from '../components/Testimonials.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/learnslice-vs-video-ihk-tools';
---

<BaseLayout
	title="LearnSlice vs. Video-Based IHK Prep Tools | Apprenticeship Platform Comparison"
	description="How AI coaching across the full apprenticeship cycle compares to video-based IHK exam-prep tools: learning approach, personalization, company knowledge, and trainer analytics."
	lang={lang}
	currentPath={currentPath}
>
	<Header logo={enContent.nav.logo} menu={enContent.nav.menu} cta={enContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="pt-32 pb-16 md:pb-24 px-6 md:px-8">
		<div class="max-w-3xl mx-auto text-center">
			<span class="section-label mb-5 block">Comparison</span>
			<h1 class="text-display-sm md:text-display text-white mb-6">LearnSlice vs. video-based IHK prep tools</h1>
			<p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">Many apprenticeship platforms center on pre-recorded video lessons for IHK exam prep. LearnSlice takes a different approach: AI coaching that adapts to each apprentice across the full training cycle.</p>
		</div>
	</section>

	<!-- Overview cards -->
	<section class="py-12 px-6 md:px-8">
		<div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
			<div class="bg-surface p-8">
				<h3 class="text-base font-semibold text-white mb-3">Video-based IHK prep tools</h3>
				<p class="text-sm text-muted leading-relaxed mb-4">A common category of apprenticeship tools: pre-recorded video lessons and practice exercises focused on IHK exam preparation, usually drawing on a fixed, ready-made content library.</p>
				<ul class="text-sm text-muted space-y-2">
					<li>Video lessons + practice exercises</li>
					<li>Focus on IHK exam preparation</li>
					<li>Pre-set, ready-made content paths</li>
					<li>Broad profession coverage</li>
				</ul>
			</div>
			<div class="bg-surface p-8 relative">
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(124, 92, 252, 1) 0%, transparent 60%);"></div>
				<h3 class="text-base font-semibold text-primary mb-3 relative">LearnSlice</h3>
				<p class="text-sm text-muted leading-relaxed mb-4 relative">A B2B AI-powered platform for the full apprenticeship cycle. Combines IHK exam prep with onboarding, upskilling, and company knowledge, all through personalized AI coaching.</p>
				<ul class="text-sm text-white/70 space-y-2 relative">
					<li>AI coaching with personalized learning paths</li>
					<li>Full cycle: IHK + onboarding + upskilling</li>
					<li>Company knowledge integration via document upload</li>
					<li>Real-time trainer analytics</li>
				</ul>
			</div>
		</div>
	</section>

	<!-- Feature comparison -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-4xl mx-auto">
			<div class="text-center mb-14"><span class="section-label mb-4 block">Features</span><h2 class="text-heading md:text-display-sm text-white m-0">Feature-by-Feature Comparison</h2></div>
			<div class="overflow-x-auto rounded-xl border border-border">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Feature</th>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Video-based IHK tools</th>
							<th class="text-left text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3 bg-primary/5"><span class="text-primary">LearnSlice</span></th>
						</tr>
					</thead>
					<tbody class="text-sm">
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Learning approach</td><td class="text-muted p-4 border-b border-border">Pre-recorded video + exercises</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">AI chat coaching + adaptive paths</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Personalization</td><td class="text-muted p-4 border-b border-border">Pre-set content paths</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Full AI adaptation per learner</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Training cycle</td><td class="text-muted p-4 border-b border-border">IHK exam-prep focus</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">IHK + onboarding + upskilling + company knowledge</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Company knowledge</td><td class="text-muted p-4 border-b border-border">Typically standard curriculum</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Upload docs, AI learns them</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">IHK exam alignment</td><td class="text-muted p-4 border-b border-border">Profession-based coverage</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Mapped per profession & region</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">AI coaching</td><td class="text-muted p-4 border-b border-border">Varies by provider</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Full conversational AI tutor 24/7</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Trainer analytics</td><td class="text-muted p-4 border-b border-border">Progress tracking</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Executive dashboards with ROI data</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Content format</td><td class="text-muted p-4 border-b border-border">Pre-recorded video</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Interactive AI conversations + assessments</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Data hosting</td><td class="text-muted p-4 border-b border-border">Typically EU</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Germany only</td></tr>
						<tr><td class="text-white/70 p-4 font-medium">Onboarding support</td><td class="text-muted p-4">Varies by provider</td><td class="text-white p-4 bg-primary/[0.03] font-medium">Dedicated setup + support</td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- When to choose -->
	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16"><span class="section-label mb-4 block">Decision</span><h2 class="text-heading md:text-display-sm text-white m-0">When to Choose What</h2></div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8">
					<h3 class="text-base font-semibold text-white mb-4">Choose a video-based IHK tool if you...</h3>
					<ul class="text-sm text-muted space-y-3">
						<li>Mainly need IHK exam-prep content across many professions</li>
						<li>Prefer pre-recorded video learning</li>
						<li>Want a large, ready-made content library</li>
						<li>Don't need company-specific knowledge or adaptive AI coaching</li>
					</ul>
				</div>
				<div class="bg-surface p-8 relative">
					<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(124, 92, 252, 1) 0%, transparent 60%);"></div>
					<h3 class="text-base font-semibold text-primary mb-4 relative">Choose LearnSlice if you...</h3>
					<ul class="text-sm text-white/70 space-y-3 relative">
						<li>Want the full training cycle, not just exam prep</li>
						<li>Need AI coaching that adapts to each apprentice 24/7</li>
						<li>Want to integrate your company's own knowledge and processes</li>
						<li>Need trainer analytics and ROI measurement</li>
						<li>Require data hosted exclusively in Germany</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={enContent.trustedBy.headline} logos={enContent.trustedBy.logos} />
	<Testimonials headline={enContent.testimonials.headline} items={enContent.testimonials.items} currentLang={lang} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={enContent.cta.headline} subheadline={enContent.cta.subheadline} button={enContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={enContent.footer.privacyLabel} termsLabel={enContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import DataBars from '../components/DataBars.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/research';
const r = enContent.research;
---

<BaseLayout
	title="Research & Evidence: AI Learning Platform | LearnSlice"
	description="LearnSlice is co-developed with FH Dortmund in a federally funded research project. See what the first university pilot found: source-traceable answers, German hosting, and curriculum-anchored learning."
	lang={lang}
	currentPath={currentPath}
	breadcrumbTitle="Research & Evidence"
>
	<Header logo={enContent.nav.logo} menu={enContent.nav.menu} cta={enContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<!-- Hero -->
	<section class="pt-32 pb-10 md:pb-14 px-6 md:px-8">
		<div class="max-w-3xl mx-auto text-center">
			<span class="section-label mb-5 block">{r.label}</span>
			<h1 class="text-display-sm md:text-display text-white mb-6">{r.headline.split('\n').map((line, i) => (<>{i > 0 && <br />}{line}</>))}</h1>
			<p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">{r.subheadline}</p>
		</div>
	</section>

	<!-- What the study looked at -->
	<section class="pb-14 md:pb-20 px-6 md:px-8 border-t border-border/50 pt-14 md:pt-20">
		<div class="max-w-3xl mx-auto text-center">
			<h2 class="text-heading md:text-display-sm text-white mb-6">{r.context.headline}</h2>
			<p class="text-base text-muted leading-relaxed m-0 max-w-2xl mx-auto text-left">{r.context.body}</p>
		</div>
	</section>

	<!-- The gaps students reported -->
	<DataBars label={r.challenges.label} headline={r.challenges.headline} intro={r.challenges.intro} items={r.challenges.items} color="accent" />

	<!-- How it teaches -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto"><span class="section-label mb-4 block">{r.didactics.label}</span><h2 class="text-heading md:text-display-sm text-white m-0 mb-4">{r.didactics.headline}</h2><p class="text-base text-muted leading-relaxed m-0">{r.didactics.intro}</p></div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
				{r.didactics.items.map((item) => (
					<div class="bg-surface p-8">
						<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
			<p class="text-sm text-muted text-center mt-8 m-0">{r.didactics.roadmap}</p>
		</div>
	</section>

	<!-- Findings -->
	<section class="py-12 md:py-16 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14"><span class="section-label mb-4 block">{r.findings.label}</span><h2 class="text-heading md:text-display-sm text-white m-0">{r.findings.headline}</h2></div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
				{r.findings.items.map((item) => (
					<div class="bg-surface p-8">
						<div class="text-heading text-primary font-semibold mb-3">{item.stat}</div>
						<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Where students said LearnSlice helped more -->
	<DataBars label={r.comparison.label} headline={r.comparison.headline} intro={r.comparison.intro} items={r.comparison.items} color="primary" />

	<!-- Architecture comparison -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-4xl mx-auto">
			<div class="text-center mb-14"><span class="section-label mb-4 block">{r.architecture.label}</span><h2 class="text-heading md:text-display-sm text-white m-0">{r.architecture.headline}</h2></div>
			<div class="overflow-x-auto rounded-xl border border-border">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">&nbsp;</th>
							<th class="text-left text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3 bg-primary/5"><span class="text-primary">{r.architecture.colA}</span></th>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">{r.architecture.colB}</th>
						</tr>
					</thead>
					<tbody class="text-sm">
						{r.architecture.rows.map((row, i) => {
							const last = i === r.architecture.rows.length - 1;
							const bcell = last ? '' : 'border-b border-border';
							return (
								<tr>
									<td class={`text-white/70 p-4 font-medium ${bcell}`}>{row.property}</td>
									<td class={`text-white p-4 bg-primary/[0.03] font-medium ${bcell}`}>{row.a}</td>
									<td class={`text-muted p-4 ${bcell}`}>{row.b}</td>
								</tr>
							);
						})}
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- Who it is for -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14"><span class="section-label mb-4 block">{r.audiences.label}</span><h2 class="text-heading md:text-display-sm text-white m-0">{r.audiences.headline}</h2></div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				{r.audiences.items.map((item) => (
					<div class="bg-surface p-8">
						<h3 class="text-base font-semibold text-white mb-3">{item.role}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- What we are still working on -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-3xl mx-auto bg-surface border border-border rounded-xl p-8 md:p-10">
			<span class="section-label mb-4 block">{r.limitations.label}</span>
			<h2 class="text-heading text-white mb-4 mt-0">{r.limitations.headline}</h2>
			<p class="text-base text-muted leading-relaxed m-0">{r.limitations.body}</p>
		</div>
	</section>

	<!-- Disclosure -->
	<section class="pb-16 px-6 md:px-8">
		<div class="max-w-3xl mx-auto">
			<p class="text-xs text-gray leading-relaxed m-0">{r.disclosure}</p>
		</div>
	</section>

	<CTAFooter headline={enContent.cta.headline} subheadline={enContent.cta.subheadline} button={enContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={enContent.footer.privacyLabel} termsLabel={enContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

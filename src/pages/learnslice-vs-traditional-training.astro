---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import LogosSlider from '../components/LogosSlider.astro';
import Testimonials from '../components/Testimonials.astro';
import CTAFooter from '../components/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import DemoRequestModal from '../components/DemoRequestModal.astro';
import LeadCapture from '../components/LeadCapture.astro';
import enContent from '../content/en.json';

const lang = 'en';
const currentPath = '/learnslice-vs-traditional-training';
---

<BaseLayout
	title="LearnSlice vs. Traditional Training Methods | Comparison"
	description="LearnSlice vs. traditional apprenticeship training: how AI coaching, personalised learning paths, and automated exams outperform manual methods."
	lang={lang}
	currentPath={currentPath}
>
	<Header logo={enContent.nav.logo} menu={enContent.nav.menu} cta={enContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="pt-32 pb-16 md:pb-24 px-6 md:px-8">
		<div class="max-w-3xl mx-auto text-center">
			<span class="section-label mb-5 block">Comparison</span>
			<h1 class="text-display-sm md:text-display text-white mb-6">LearnSlice vs. Traditional Training Methods</h1>
			<p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">See how AI-powered apprenticeship training compares to traditional classroom instruction, manual mentoring, and external IHK prep courses.</p>
			<p class="text-sm text-muted mt-4 max-w-xl mx-auto leading-relaxed">Figures are estimates based on our <a href="/apprenticeship-savings-calculator" class="text-primary hover:underline">cost calculator</a> and typical German market (BIBB) averages. Adjust the inputs to your own situation. Estimates, not guarantees; actual results vary by company, profession, and region. Stand: Mai 2026.</p>
		</div>
	</section>

	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-4xl mx-auto">
			<div class="overflow-x-auto rounded-xl border border-border">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Feature</th>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Traditional</th>
							<th class="text-left text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3 bg-primary/5"><span class="text-primary">LearnSlice</span></th>
						</tr>
					</thead>
					<tbody class="text-sm">
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Time to productivity</td><td class="text-muted p-4 border-b border-border">~6 months</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">8 weeks (65% faster)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Trainer time/week</td><td class="text-muted p-4 border-b border-border">8-12 hrs per apprentice</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">4-6 hrs (50% less)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Dropout rate</td><td class="text-muted p-4 border-b border-border">30% average</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">15% (halved)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Availability</td><td class="text-muted p-4 border-b border-border">Business hours</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">24/7 AI coaching</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Personalization</td><td class="text-muted p-4 border-b border-border">One curriculum for all</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Adaptive per learner</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">IHK exam prep</td><td class="text-muted p-4 border-b border-border">Typically &euro;500-&euro;2K</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Built-in, AI-generated</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Company knowledge</td><td class="text-muted p-4 border-b border-border">Manual handover</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Upload docs, AI integrates</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Progress tracking</td><td class="text-muted p-4 border-b border-border">Manual notes</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Real-time analytics</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Annual savings / apprentice</td><td class="text-muted p-4 border-b border-border">Status quo</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Up to &euro;15K*</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">GDPR</td><td class="text-muted p-4 border-b border-border">Varies</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">100%, hosted in Germany</td></tr>
						<tr><td class="text-white/70 p-4 font-medium">Scalability</td><td class="text-muted p-4">Linear cost increase</td><td class="text-white p-4 bg-primary/[0.03] font-medium">One setup, unlimited</td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16"><span class="section-label mb-4 block">Results</span><h2 class="text-heading md:text-display-sm text-white m-0">Why Companies Are Switching</h2></div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8 hover:bg-[#403930] transition-colors duration-200">
					<div class="text-2xl font-bold text-primary mb-2 tracking-tight">Up to &euro;15K</div>
					<h3 class="text-base font-semibold text-white mb-2">Saved per apprentice</h3>
					<p class="text-base text-muted leading-relaxed m-0">Reduced trainer time, eliminated external courses, faster productivity, fewer costly dropouts.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#403930] transition-colors duration-200">
					<div class="text-2xl font-bold text-primary mb-2 tracking-tight">24/7</div>
					<h3 class="text-base font-semibold text-white mb-2">AI coaching availability</h3>
					<p class="text-base text-muted leading-relaxed m-0">The AI coach answers questions, explains concepts, and provides practice exercises anytime.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#403930] transition-colors duration-200">
					<div class="text-2xl font-bold text-primary mb-2 tracking-tight">8 wks</div>
					<h3 class="text-base font-semibold text-white mb-2">To full productivity</h3>
					<p class="text-base text-muted leading-relaxed m-0">IHK learning paths combined with company knowledge get apprentices contributing 65% faster.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={enContent.trustedBy.headline} logos={enContent.trustedBy.logos} />
	<Testimonials headline={enContent.testimonials.headline} items={enContent.testimonials.items} currentLang={lang} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={enContent.cta.headline} subheadline={enContent.cta.subheadline} button={enContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={enContent.footer.privacyLabel} termsLabel={enContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

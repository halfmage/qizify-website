---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import ProblemStatement from '../../components/ProblemStatement.astro';
import SavingsComparison from '../../components/SavingsComparison.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import LearningResults from '../../components/LearningResults.astro';
import CompanySlider from '../../components/CompanySlider.astro';
import Testimonials from '../../components/Testimonials.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import VocationalProfessions from '../../components/VocationalProfessions.astro';
import FAQ from '../../components/FAQ.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de';
---

<BaseLayout 
	title="KI-Ausbildung & IHK-Prüfungsvorbereitung | LearnSlice"
	description="KI-Plattform für die gesamte Berufsausbildung: IHK-Prüfung, Onboarding und Upskilling vereint. Bis zu €15K Ersparnis pro Azubi, Ausbilder spürbar entlastet."
	lang={lang}
	currentPath={currentPath}
	heroImage="/images/hero/hero-background.webp"
>
	<Header
		logo={deContent.nav.logo}
		menu={deContent.nav.menu}
		cta={deContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>
	
	<Hero
		headline={deContent.hero.headline}
		subheadline={deContent.hero.subheadline}
		ctaPrimary={deContent.hero.ctaPrimary}
		ctaSecondary={deContent.hero.ctaSecondary}
		stats={deContent.hero.stats}
		currentLang={lang}
	/>
	
	<LogosSlider 
		headline={deContent.trustedBy.headline}
		logos={deContent.trustedBy.logos}
	/>
	
	<ProblemStatement
		badge={deContent.problem.badge}
		headline={deContent.problem.headline}
		body={deContent.problem.body}
	/>

	<SavingsComparison
		headline={deContent.savingsComparison.headline}
		without={deContent.savingsComparison.without}
		with={deContent.savingsComparison.with}
	/>
	
	<HowItWorks
		badge={deContent.howItWorks.badge}
		headline={deContent.howItWorks.headline}
		steps={deContent.howItWorks.steps}
		lang={lang}
	/>
	
	<LearningResults 
		badge={deContent.learningResults.badge}
		headline={deContent.learningResults.headline}
		features={deContent.learningResults.features}
		compliance={deContent.learningResults.compliance}
	/>
	
	<VocationalProfessions
		headline={deContent.vocationalProfessions.headline}
		items={deContent.vocationalProfessions.items}
	/>

	<CompanySlider
		headline={deContent.madeForCompany.headline}
		tabs={deContent.madeForCompany.tabs}
	/>

	<Testimonials
		headline={deContent.testimonials.headline}
		items={deContent.testimonials.items}
		currentLang={lang}
	/>

	<WhyChooseUs
		headline={deContent.whyChooseUs.headline}
		items={deContent.whyChooseUs.items}
	/>

	<FAQ
		headline={deContent.faq.headline}
		items={deContent.faq.items}
	/>

	<CTAFooter
		headline={deContent.homepageCta.headline}
		subheadline={deContent.homepageCta.subheadline}
		button={deContent.homepageCta.button}
		currentLang={lang}
	/>
	
	<Footer
		currentLang={lang}
		privacyLabel={deContent.footer.privacyLabel}
		termsLabel={deContent.footer.termsLabel}
	/>

	<div class="md:hidden h-20" aria-hidden="true"></div>

	<a
		href="#demo-request"
		class="md:hidden fixed bottom-0 left-0 right-0 z-40 mx-3 mb-[max(0.75rem,env(safe-area-inset-bottom))] text-center bg-primary text-white px-4 py-3 rounded-lg font-medium text-sm shadow-2xl shadow-black/40 hover:bg-[#6a4ae0] transition-colors"
	>
		Kostenlose Demo buchen
	</a>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>


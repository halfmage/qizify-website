---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import ProblemStatement from '../../components/ProblemStatement.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import ConsultationModal from '../../components/ConsultationModal.astro';
import Button from '../../components/Button.astro';
import UseCaseSlider from '../../components/UseCaseSlider.astro';
import { Icon } from 'astro-icon/components';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/loesungen';
const s = deContent.solutions;

// Intrinsic dimensions of the use-case screenshots (prevent layout shift), in item order.
const ucDims = [
	{ w: 2890, h: 1516 },
	{ w: 2620, h: 1432 },
	{ w: 2912, h: 1570 },
	{ w: 1950, h: 1190 },
];
// Reihenfolge des Projekt-Sliders (Tab 1 ist standardmäßig sichtbar):
// Branchenlösung zuerst, dann benannte Hochschule (FH Dortmund), KI-Flaggschiff, Moodle zum Schluss.
const ucOrder = [2, 1, 0, 3];
const ucItems = ucOrder.map((i) => s.useCases.items[i]);
const ucItemDims = ucOrder.map((i) => ucDims[i]);

const heroImage = '/images/solutions/learnslice-home.webp';
const heroImageAlt = 'Der LearnSlice-Startbildschirm: Level-Fortschritt, vorgeschlagene nächste Übungen sowie Bereiche für IHK-Prüfungen, Onboarding und Weiterbildung';
---

<BaseLayout
	title="Lernsoftware-Engineering: Apps, LMS, Chatbots | LearnSlice"
	description="Wir sind ein Software-Engineering-Unternehmen, das Lernsoftware jeder Art baut: KI-Tutoren, LMS, mobile Apps, Simulationen, Quiz- und Assessment-Plattformen. Souverän, DSGVO- und EU-KI-Verordnungs-konform, vertraut von Hochschulen, Schulen und Lern-Communities."
	lang={lang}
	currentPath={currentPath}
	breadcrumbTitle="Lösungen"
>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={s.hero.ctaPrimary} ctaModalTrigger="project-inquiry" currentLang={lang} currentPath={currentPath} />

	<!-- Hero: Copy + Produkt-Screenshot (Produkt-Hero konvertiert, Stockfoto nicht) -->
	<section class="relative overflow-hidden pt-28 md:pt-32 pb-12 md:pb-20 px-6 md:px-8">
		<div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[520px] pointer-events-none glow-aurora opacity-40" aria-hidden="true"></div>
		<div class="max-w-container mx-auto relative z-10 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
			<div class="max-w-xl">
				<span class="section-label mb-5 block">{s.hero.label}</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">
					{s.hero.headline.split('\n').map((line, i, arr) => (
						<>{i > 0 && <br />}<span class={i === arr.length - 1 ? 'gradient-text-primary' : ''}>{line}</span></>
					))}
				</h1>
				<p class="text-lg text-muted mb-6 leading-relaxed">{s.hero.subheadline}</p>
				<div class="flex flex-wrap items-center gap-3 mb-3">
					<Button variant="primary" href="#project-inquiry" data-modal-trigger="project-inquiry" aria-label={s.hero.ctaPrimary}>{s.hero.ctaPrimary}</Button>
					<Button variant="secondary" href="#selected-work" aria-label={s.hero.ctaSecondary}>{s.hero.ctaSecondary}</Button>
				</div>
				<p class="text-sm text-muted mb-1.5">{s.hero.microcopy}</p>
				<p class="text-sm text-white/70 mb-6">{s.hero.riskReversal}</p>
				<div class="flex items-center gap-2.5 text-xs md:text-sm text-muted border-t border-white/10 pt-5">
					<Icon name="hugeicons:security-check" class="w-4 h-4 text-primary shrink-0" />
					<span>{s.hero.trust}</span>
				</div>
			</div>
			<div class="relative">
				<div class="absolute -inset-6 glow-aurora opacity-70 pointer-events-none" aria-hidden="true"></div>
				<div class="relative rounded-xl border border-border-light overflow-hidden shadow-2xl shadow-black/50">
					<img src={heroImage} alt={heroImageAlt} width="1600" height="910" loading="eager" fetchpriority="high" decoding="async" class="w-full h-auto block" />
				</div>
			</div>
		</div>
	</section>

	<!-- Above-the-fold proof: named-customer line + logos -->
	<LogosSlider headline={s.trustedByLine} logos={deContent.trustedBy.logos} />

	<!-- Was wir bauen: fokussierter Katalog (Top 6) -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{s.build.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-4">{s.build.headline}</h2>
				<p class="text-base text-muted leading-relaxed m-0">{s.build.intro}</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				{s.build.items.slice(0, 6).map((item, i) => (
					<div class={`card-hover-glow ${i % 2 === 0 ? 'card-hover-glow-primary' : 'card-hover-glow-accent'} bg-surface p-7 group hover:bg-[#403930] transition-colors duration-200`}>
						<div class={`w-11 h-11 rounded-lg flex items-center justify-center mb-4 ${i % 2 === 0 ? 'bg-primary/10' : 'bg-accent/10'} group-hover:scale-110 transition-transform duration-200`}>
							<Icon name={item.icon} class={`w-5 h-5 ${i % 2 === 0 ? 'text-primary' : 'text-accent'}`} />
						</div>
						<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
			<p class="text-sm text-white/90 text-center mt-8 m-0">{s.build.note}</p>
		</div>
	</section>

	<!-- Ausgewählte Projekte: klickbarer Use-Case-Slider -->
	<UseCaseSlider
		label={s.useCases.label}
		headline={s.useCases.headline}
		intro={s.useCases.intro}
		items={ucItems}
		dims={ucItemDims}
		sectionId="selected-work"
	/>

	<!-- Mittlerer CTA -->
	<section class="py-12 md:py-16 px-6 md:px-8">
		<div class="max-w-3xl mx-auto relative">
			<div class="absolute -inset-4 glow-aurora opacity-50 pointer-events-none" aria-hidden="true"></div>
			<div class="relative bg-surface border border-border rounded-2xl p-8 md:p-12 text-center overflow-hidden">
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-3">{s.midCta.headline}</h2>
				<p class="text-base text-muted leading-relaxed max-w-xl mx-auto mb-6 m-0">{s.midCta.sub}</p>
				<Button variant="primary" href="#project-inquiry" data-modal-trigger="project-inquiry" aria-label={s.midCta.button}>{s.midCta.button}</Button>
				<p class="text-sm text-muted mt-4 mb-0">{s.midCta.note}</p>
				<p class="text-xs text-white/55 mt-1.5 mb-0">{s.midCta.riskReversal}</p>
			</div>
		</div>
	</section>

	<!-- Problem: warum Standardtools scheitern, direkt vor der Souveränitäts-Antwort -->
	<ProblemStatement badge={s.problem.badge} headline={s.problem.headline} body={s.problem.body} />

	<!-- Warum wir: Souveränität und Vertrauen (beantwortet das Problem oben) -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{s.sovereignty.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">{s.sovereignty.headline}</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				{s.sovereignty.items.map((item, i) => (
					<div class={`card-hover-glow ${i % 2 === 0 ? 'card-hover-glow-primary' : 'card-hover-glow-accent'} bg-surface p-8 group hover:bg-[#403930] transition-colors duration-200`}>
						<div class={`w-11 h-11 rounded-lg flex items-center justify-center mb-4 ${i % 2 === 0 ? 'bg-primary/10' : 'bg-accent/10'} group-hover:scale-110 transition-transform duration-200`}>
							<Icon name={item.icon} class={`w-5 h-5 ${i % 2 === 0 ? 'text-primary' : 'text-accent'}`} />
						</div>
						<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- So arbeiten wir: Prozess + Engagement-Modelle, zusammengeführt -->
	<section class="py-12 md:py-20 px-6 md:px-8 border-t border-border/50">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{s.process.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">{s.process.headline}</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border rounded-xl overflow-hidden">
				{s.process.steps.map((step) => (
					<div class="card-hover-glow card-hover-glow-primary bg-surface p-7 group hover:bg-[#403930] transition-colors duration-200">
						<div class="flex items-center justify-between mb-4">
							<div class="w-11 h-11 rounded-lg bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-200">
								<Icon name={step.icon} class="w-5 h-5 text-primary" />
							</div>
							<span class="font-mono text-label text-primary/70">0{step.number}</span>
						</div>
						<h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
						<p class="text-sm text-muted leading-relaxed m-0">{step.body}</p>
					</div>
				))}
			</div>

			<!-- Engagement-Modelle -->
			<div class="mt-14 md:mt-16">
				<div class="text-center mb-8 max-w-2xl mx-auto">
					<h3 class="text-heading-sm md:text-heading text-white m-0">{s.engagement.headline}</h3>
					<p class="text-base text-muted leading-relaxed mt-3 m-0">{s.engagement.intro}</p>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border rounded-xl overflow-hidden">
					{s.engagement.items.map((item, i) => (
						<div class={`card-hover-glow ${i % 2 === 0 ? 'card-hover-glow-primary' : 'card-hover-glow-accent'} bg-surface p-7 group hover:bg-[#403930] transition-colors duration-200`}>
							<div class={`w-11 h-11 rounded-lg flex items-center justify-center mb-4 ${i % 2 === 0 ? 'bg-primary/10' : 'bg-accent/10'} group-hover:scale-110 transition-transform duration-200`}>
								<Icon name={item.icon} class={`w-5 h-5 ${i % 2 === 0 ? 'text-primary' : 'text-accent'}`} />
							</div>
							<h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
							<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Social Proof: Testimonials mit Gesichtern -->
	<Testimonials headline={s.social.headline} items={deContent.testimonials.items} currentLang={lang} />

	<!-- Zweiter CTA: nach dem Beweis konvertieren -->
	<section class="py-12 md:py-16 px-6 md:px-8">
		<div class="max-w-3xl mx-auto relative">
			<div class="absolute -inset-4 glow-aurora opacity-50 pointer-events-none" aria-hidden="true"></div>
			<div class="relative bg-surface border border-border rounded-2xl p-8 md:p-12 text-center overflow-hidden">
				<h2 class="text-heading md:text-display-sm text-white m-0 mb-3">{s.midCta2.headline}</h2>
				<p class="text-base text-muted leading-relaxed max-w-xl mx-auto mb-6 m-0">{s.midCta2.sub}</p>
				<Button variant="primary" href="#project-inquiry" data-modal-trigger="project-inquiry" aria-label={s.midCta.button}>{s.midCta.button}</Button>
				<p class="text-sm text-muted mt-4 mb-0">{s.midCta.note}</p>
			</div>
		</div>
	</section>

	<!-- Branchen, für die wir bauen (informative Karten) -->
	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-14 max-w-2xl mx-auto">
				<span class="section-label mb-4 block">{s.audiences.label}</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">{s.audiences.headline}</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				{s.audiences.items.map((item, i) => (
					<div class={`card-hover-glow ${i % 2 === 0 ? 'card-hover-glow-primary' : 'card-hover-glow-accent'} bg-surface p-8 group hover:bg-[#403930] transition-colors duration-200`}>
						<div class="flex items-center gap-3 mb-3">
							<div class={`w-11 h-11 rounded-lg flex items-center justify-center ${i % 2 === 0 ? 'bg-primary/10' : 'bg-accent/10'} group-hover:scale-110 transition-transform duration-200`}>
								<Icon name={item.icon} class={`w-5 h-5 ${i % 2 === 0 ? 'text-primary' : 'text-accent'}`} />
							</div>
							<h3 class="text-base font-semibold text-white m-0">{item.role}</h3>
						</div>
						<p class="text-sm text-muted leading-relaxed m-0">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<FAQ headline={s.faq.headline} items={s.faq.items.slice(0, 6)} />

	<CTAFooter headline={s.cta.headline} subheadline={s.cta.subheadline} button={s.cta.button} buttonHref="#project-inquiry" note={s.cta.note} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} />

	<!-- Sticky Mobile CTA: durchgehender Conversion-Pfad auf langer Seite -->
	<div class="md:hidden h-20" aria-hidden="true"></div>
	<a
		href="#project-inquiry"
		data-modal-trigger="project-inquiry"
		class="md:hidden fixed bottom-0 left-0 right-0 z-40 mx-3 mb-[max(0.75rem,env(safe-area-inset-bottom))] text-center bg-primary text-white px-4 py-3 rounded-lg font-medium text-sm shadow-2xl shadow-black/40 hover:bg-[#6a4ae0] transition-colors"
	>
		{s.hero.ctaPrimary}
	</a>

	<ConsultationModal currentLang={lang} />
</BaseLayout>

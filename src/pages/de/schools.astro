---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/schools';
---

<BaseLayout
	title="KI-Lernplattform f\u00FCr Berufsschulen | LearnSlice"
	description="Steigern Sie die \u00DCbergangsquote in Ausbildung um 15-25 %, reduzieren Sie Abbr\u00FCche um 30 % und sparen Sie Lehrkr\u00E4ften 25 % ihrer Zeit."
	lang={lang}
	currentPath={currentPath}
>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={deContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="relative min-h-[75vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-12 md:py-16">
			<div class="max-w-[700px]">
				<span class="section-label mb-5 block">F&uuml;r Berufsschulen</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">Bessere Pr&uuml;fungsergebnisse.<br />Weniger Arbeitsaufwand.</h1>
				<p class="text-lg text-muted mb-8 max-w-[560px] leading-relaxed">Personalisiertes KI-Coaching, abgestimmt auf IHK-Pr&uuml;fungsanforderungen. Automatisierte &Uuml;bungen, Echtzeit-Feedback und adaptive Lernpfade.</p>
				<a href="#demo-request" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-[#6a4ae0] transition-colors">Demo anfordern <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
			</div>
		</div>
	</section>

	<section class="py-16 px-6 md:px-8 border-t border-border">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">15-25 %</div><div class="text-muted text-xs">H&ouml;here &Uuml;bergangsquote</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">30 %</div><div class="text-muted text-xs">Weniger Abbr&uuml;che im ersten Jahr</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">25 %</div><div class="text-muted text-xs">Zeitersparnis f&uuml;r Lehrkr&auml;fte</div></div>
			</div>
		</div>
	</section>

	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16">
				<span class="section-label mb-4 block">Vorteile</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">So unterst&uuml;tzt LearnSlice Berufsschulen</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">IHK-ausgerichtete Inhalte</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Vorgefertigte Lernpfade, abgestimmt auf IHK-Pr&uuml;fungsanforderungen. Sch&uuml;ler &uuml;ben mit pr&uuml;fungsnahen Fragen.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">24/7 KI-Nachhilfe</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Personalisiertes Coaching au&szlig;erhalb der Unterrichtszeiten. Die KI identifiziert Wissensl&uuml;cken und erstellt gezielte &Uuml;bungen.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">Analytics-Dashboard</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Sch&uuml;lerfortschritt auf einen Blick. Gef&auml;hrdete Sch&uuml;ler fr&uuml;hzeitig erkennen, Leistungstrends verfolgen.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={deContent.trustedBy.headline} logos={deContent.trustedBy.logos} />
	<Testimonials headline={deContent.testimonials.headline} items={deContent.testimonials.items} currentLang={lang} />
	<WhyChooseUs headline={deContent.whyChooseUs.headline} items={deContent.whyChooseUs.items} />
	<FAQ headline={deContent.faq.headline} items={deContent.faq.items} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={deContent.cta.headline} subheadline={deContent.cta.subheadline} button={deContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

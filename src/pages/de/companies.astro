---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import SavingsComparison from '../../components/SavingsComparison.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/companies';
---

<BaseLayout
	title="KI-gest\u00FCtzte Ausbildung f\u00FCr Unternehmen | LearnSlice"
	description="Verk\u00FCrzen Sie das Azubi-Onboarding von 6 Monaten auf 8 Wochen. Sparen Sie \u20AC32K pro Azubi mit KI-Coaching, IHK-Pr\u00FCfungsvorbereitung und Integration Ihres Unternehmenswissens."
	lang={lang}
	currentPath={currentPath}
>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={deContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="relative min-h-[75vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-12 md:py-16">
			<div class="max-w-[700px]">
				<span class="section-label mb-5 block">F&uuml;r Unternehmen</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">Jeder Azubi wird in 8 Wochen zum Leistungstr&auml;ger</h1>
				<p class="text-lg text-muted mb-8 max-w-[560px] leading-relaxed">LearnSlice verbindet IHK-Pr&uuml;fungsvorbereitung mit Ihrem Unternehmenswissen zu personalisierten KI-Lernpfaden. Ihre Azubis sind 65 % schneller einsatzbereit.</p>
				<div class="flex flex-col sm:flex-row gap-3">
					<a href="#demo-request" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-[#6a4ae0] transition-colors">Demo anfordern <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
					<a href="#savings" class="inline-flex items-center justify-center px-4 py-2 border border-border-light text-muted text-sm font-medium rounded-lg hover:text-white hover:border-white/30 transition-colors">ROI ansehen</a>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 px-6 md:px-8 border-t border-border">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">65 %</div><div class="text-muted text-xs">Schneller einsatzbereit</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">&euro;32K</div><div class="text-muted text-xs">Ersparnis pro Azubi</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">50 %</div><div class="text-muted text-xs">Weniger Ausbilderzeit</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">15 %</div><div class="text-muted text-xs">Abbruchquote (statt 30 %)</div></div>
			</div>
		</div>
	</section>

	<div id="savings"><SavingsComparison headline={deContent.savingsComparison.headline} without={deContent.savingsComparison.without} with={deContent.savingsComparison.with} /></div>
	<HowItWorks badge={deContent.howItWorks.badge} headline={deContent.howItWorks.headline} steps={deContent.howItWorks.steps} />
	<LogosSlider headline={deContent.trustedBy.headline} logos={deContent.trustedBy.logos} />
	<Testimonials headline={deContent.testimonials.headline} items={deContent.testimonials.items} currentLang={lang} />
	<WhyChooseUs headline={deContent.whyChooseUs.headline} items={deContent.whyChooseUs.items} />
	<FAQ headline={deContent.faq.headline} items={deContent.faq.items} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={deContent.cta.headline} subheadline={deContent.cta.subheadline} button={deContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

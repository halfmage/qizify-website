---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import SavingsComparison from '../../components/SavingsComparison.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/companies';
---

<BaseLayout
	title="KI-gestützte Ausbildung für Unternehmen | LearnSlice"
	description="Verkürzen Sie das Azubi-Onboarding von 6 Monaten auf 8 Wochen. Sparen Sie €32K pro Azubi mit KI-Coaching, IHK-Prüfungsvorbereitung und Integration Ihres Unternehmenswissens."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={deContent.nav.logo}
		menu={deContent.nav.menu}
		cta={deContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<!-- Hero -->
	<section class="py-16 md:py-24 px-4 md:px-8 bg-dark relative overflow-hidden">
		<div class="absolute inset-0 z-0">
			<img src="/images/hero/hero-background.webp" alt="" class="w-full h-full object-cover opacity-30" aria-hidden="true" />
			<div class="absolute inset-0 bg-gradient-to-b from-dark/40 via-dark/80 to-dark"></div>
		</div>
		<div class="max-w-container mx-auto relative z-10">
			<div class="max-w-3xl">
				<div class="inline-block px-4 py-2 bg-primary/20 border border-primary rounded-full text-white text-sm font-medium uppercase tracking-wider mb-6">
					Für Unternehmen
				</div>
				<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
					Jeder Azubi wird in<br />8 Wochen zum Leistungsträger
				</h1>
				<p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl leading-relaxed">
					LearnSlice verbindet IHK-Prüfungsvorbereitung mit Ihrem Unternehmenswissen zu personalisierten KI-Lernpfaden. Ihre Azubis sind 65 % schneller einsatzbereit und Ihre Ausbilder werden um 50 % entlastet.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="#demo-request" class="inline-flex items-center justify-center px-8 py-4 bg-white text-black font-semibold rounded-xl hover:bg-white/90 transition-colors">
						Demo anfordern
					</a>
					<a href="#savings" class="inline-flex items-center justify-center px-8 py-4 border border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors">
						ROI ansehen
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Key metrics -->
	<section class="py-12 md:py-16 px-4 md:px-8 bg-dark border-t border-white/10">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">65 %</div>
					<div class="text-white/70 text-sm">Schneller einsatzbereit</div>
				</div>
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">€32K</div>
					<div class="text-white/70 text-sm">Ersparnis pro Azubi</div>
				</div>
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">50 %</div>
					<div class="text-white/70 text-sm">Weniger Ausbilderzeit</div>
				</div>
				<div class="text-center">
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2">15 %</div>
					<div class="text-white/70 text-sm">Abbruchquote (statt 30 %)</div>
				</div>
			</div>
		</div>
	</section>

	<div id="savings">
		<SavingsComparison
			headline={deContent.savingsComparison.headline}
			without={deContent.savingsComparison.without}
			with={deContent.savingsComparison.with}
		/>
	</div>

	<HowItWorks
		badge={deContent.howItWorks.badge}
		headline={deContent.howItWorks.headline}
		steps={deContent.howItWorks.steps}
	/>

	<LogosSlider
		headline={deContent.trustedBy.headline}
		logos={deContent.trustedBy.logos}
	/>

	<Testimonials
		headline={deContent.testimonials.headline}
		items={deContent.testimonials.items}
		currentLang={lang}
	/>

	<LeadCapture currentLang={lang} />

	<FAQ
		headline={deContent.faq.headline}
		items={deContent.faq.items}
	/>

	<CTAFooter
		headline={deContent.cta.headline}
		subheadline={deContent.cta.subheadline}
		button={deContent.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={deContent.footer.privacyLabel}
		termsLabel={deContent.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import Testimonials from '../../components/Testimonials.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/learnslice-vs-prozubi';
---

<BaseLayout title="LearnSlice vs. Prozubi: KI-Coaching vs. Video-Lernen f&uuml;r die Ausbildung" description="Detaillierter Vergleich von LearnSlice und Prozubi f&uuml;r die Berufsausbildung. KI-Coaching vs. Video-Inhalte, voller Ausbildungszyklus vs. IHK-Pr&uuml;fungsvorbereitung." lang={lang} currentPath={currentPath}>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={deContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="pt-32 pb-16 md:pb-24 px-6 md:px-8">
		<div class="max-w-3xl mx-auto text-center">
			<span class="section-label mb-5 block">Vergleich</span>
			<h1 class="text-display-sm md:text-display text-white mb-6">LearnSlice vs. Prozubi</h1>
			<p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">Prozubi unterst&uuml;tzt Azubis seit &uuml;ber 10 Jahren bei der IHK-Pr&uuml;fungsvorbereitung. LearnSlice geht einen anderen Weg &mdash; und deckt den gesamten Ausbildungszyklus mit KI ab.</p>
		</div>
	</section>

	<section class="py-12 px-6 md:px-8">
		<div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
			<div class="bg-surface p-8">
				<h3 class="text-base font-semibold text-white mb-3">Prozubi</h3>
				<p class="text-sm text-muted leading-relaxed mb-4">Etablierte videobasierte Lernplattform f&uuml;r die IHK-Pr&uuml;fungsvorbereitung mit 200+ Berufen. Seit &uuml;ber 10 Jahren am Markt.</p>
				<ul class="text-sm text-muted space-y-2"><li>Video-Lektionen + &Uuml;bungsaufgaben</li><li>200+ Ausbildungsberufe</li><li>Fokus auf IHK-Pr&uuml;fungsvorbereitung</li><li>10+ Jahre Content-Expertise</li></ul>
			</div>
			<div class="bg-surface p-8 relative">
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(124, 92, 252, 1) 0%, transparent 60%);"></div>
				<h3 class="text-base font-semibold text-primary mb-3 relative">LearnSlice</h3>
				<p class="text-sm text-muted leading-relaxed mb-4 relative">B2B-KI-Plattform f&uuml;r den gesamten Ausbildungszyklus. Verbindet IHK-Vorbereitung mit Onboarding, Upskilling und Unternehmenswissen.</p>
				<ul class="text-sm text-white/70 space-y-2 relative"><li>KI-Coaching mit personalisierten Lernpfaden</li><li>Voller Zyklus: IHK + Onboarding + Upskilling</li><li>Unternehmenswissen-Integration per Dokumenten-Upload</li><li>Echtzeit-Analytics f&uuml;r Ausbilder</li></ul>
			</div>
		</div>
	</section>

	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-4xl mx-auto">
			<div class="text-center mb-14"><span class="section-label mb-4 block">Features</span><h2 class="text-heading md:text-display-sm text-white m-0">Feature-Vergleich im Detail</h2></div>
			<div class="overflow-x-auto rounded-xl border border-border">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Merkmal</th>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Prozubi</th>
							<th class="text-left text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3 bg-primary/5"><span class="text-primary">LearnSlice</span></th>
						</tr>
					</thead>
					<tbody class="text-sm">
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Lernansatz</td><td class="text-muted p-4 border-b border-border">Video-Lektionen + &Uuml;bungen</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">KI-Chat-Coaching + adaptive Pfade</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Personalisierung</td><td class="text-muted p-4 border-b border-border">Feste Lernpfade</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Volle KI-Anpassung pro Lernenden</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Ausbildungszyklus</td><td class="text-muted p-4 border-b border-border">Nur IHK-Pr&uuml;fungsvorbereitung</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">IHK + Onboarding + Upskilling + Unternehmenswissen</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Unternehmenswissen</td><td class="text-muted p-4 border-b border-border">Nicht verf&uuml;gbar</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Dokumente hochladen, KI lernt</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">IHK-Ausrichtung</td><td class="text-muted p-4 border-b border-border">200+ Berufe abgedeckt</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Nach Beruf &amp; Region</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">KI-Coaching</td><td class="text-muted p-4 border-b border-border">Nicht verf&uuml;gbar</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Voller KI-Tutor 24/7</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Ausbilder-Analytics</td><td class="text-muted p-4 border-b border-border">Basis-Fortschrittstracking</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Executive Dashboards mit ROI-Daten</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Content-Format</td><td class="text-muted p-4 border-b border-border">Vorproduzierte Videos</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Interaktive KI-Gespr&auml;che + Assessments</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Daten-Hosting</td><td class="text-muted p-4 border-b border-border">EU</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Deutschland</td></tr>
						<tr><td class="text-white/70 p-4 font-medium">Onboarding-Support</td><td class="text-muted p-4">Self-Service</td><td class="text-white p-4 bg-primary/[0.03] font-medium">Pers&ouml;nliches Setup + Support</td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16"><span class="section-label mb-4 block">Entscheidung</span><h2 class="text-heading md:text-display-sm text-white m-0">Wann welche Plattform w&auml;hlen</h2></div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8">
					<h3 class="text-base font-semibold text-white mb-4">W&auml;hlen Sie Prozubi, wenn Sie...</h3>
					<ul class="text-sm text-muted space-y-3"><li>IHK-Pr&uuml;fungsinhalte f&uuml;r viele Berufe brauchen</li><li>Videobasiertes Lernen bevorzugen</li><li>Eine bew&auml;hrte Content-Bibliothek mit 10+ Jahren Material w&uuml;nschen</li><li>Kein Unternehmenswissen integrieren m&uuml;ssen</li></ul>
				</div>
				<div class="bg-surface p-8 relative">
					<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(124, 92, 252, 1) 0%, transparent 60%);"></div>
					<h3 class="text-base font-semibold text-primary mb-4 relative">W&auml;hlen Sie LearnSlice, wenn Sie...</h3>
					<ul class="text-sm text-white/70 space-y-3 relative"><li>Den gesamten Ausbildungszyklus abdecken wollen</li><li>KI-Coaching brauchen, das sich an jeden Azubi anpasst</li><li>Eigenes Unternehmenswissen und Prozesse integrieren wollen</li><li>Ausbilder-Analytics und ROI-Messung ben&ouml;tigen</li><li>Daten ausschlie&szlig;lich in Deutschland gehostet brauchen</li></ul>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={deContent.trustedBy.headline} logos={deContent.trustedBy.logos} />
	<Testimonials headline={deContent.testimonials.headline} items={deContent.testimonials.items} currentLang={lang} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={deContent.cta.headline} subheadline={deContent.cta.subheadline} button={deContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

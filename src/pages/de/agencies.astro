---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/agencies';
---

<BaseLayout
	title="KI-Training f\u00FCr IHK, HWK & Wirtschaftsf\u00F6rderung | LearnSlice"
	description="Machen Sie moderne Ausbildung f\u00FCr KMU bezahlbar. Gemeinsame KI-Mentoring-Lizenzen senken die Abbruchquote um 10-15 %."
	lang={lang}
	currentPath={currentPath}
>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={deContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="relative min-h-[75vh] flex items-center pt-32 pb-16 overflow-hidden">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] opacity-20 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124, 92, 252, 0.2) 0%, transparent 70%);"></div>
		<div class="max-w-container mx-auto px-6 md:px-8 relative z-10 py-12 md:py-16">
			<div class="max-w-[700px]">
				<span class="section-label mb-5 block">F&uuml;r IHK, HWK & Wirtschaftsf&ouml;rderung</span>
				<h1 class="text-display-sm md:text-display text-white mb-6">Ausbildungsabbr&uuml;che um 15 % senken &mdash; ohne mehr Ausbilder</h1>
				<p class="text-lg text-muted mb-8 max-w-[560px] leading-relaxed">KI-gest&uuml;tzte Ausbildung durch gemeinsame Lizenzmodelle f&uuml;r regionale KMU. Abbruchquoten senken, Ausbilder entlasten, Fachkr&auml;fteentwicklung st&auml;rken.</p>
				<a href="#demo-request" class="inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-[#6a4ae0] transition-colors">Demo anfordern <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
			</div>
		</div>
	</section>

	<section class="py-16 px-6 md:px-8 border-t border-border">
		<div class="max-w-container mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">10-15 %</div><div class="text-muted text-xs">Weniger Ausbildungsabbr&uuml;che</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">45-50 %</div><div class="text-muted text-xs">Weniger Betreuungsaufwand</div></div>
				<div class="text-center"><div class="text-2xl md:text-3xl font-bold text-primary mb-1.5 tracking-tight">Shared</div><div class="text-muted text-xs">Lizenzmodell f&uuml;r KMU-Zugang</div></div>
			</div>
		</div>
	</section>

	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16">
				<span class="section-label mb-4 block">Vorteile</span>
				<h2 class="text-heading md:text-display-sm text-white m-0">So profitieren Kammern und Agenturen</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">Bezahlbar f&uuml;r KMU</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Gemeinsame Lizenzmodelle machen KI-Training auch f&uuml;r kleine Unternehmen zug&auml;nglich.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">Messbare Wirkung</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Abbruchreduzierung, Pr&uuml;fungsbestehensquoten und Effizienz &uuml;ber alle Unternehmen verfolgen.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<h3 class="text-base font-semibold text-white mb-3">IHK-Pr&uuml;fungsausrichtung</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Berufsspezifische Aufgaben und Simulationen nach IHK-/HWK-Anforderungen.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={deContent.trustedBy.headline} logos={deContent.trustedBy.logos} />
	<Testimonials headline={deContent.testimonials.headline} items={deContent.testimonials.items} currentLang={lang} />
	<WhyChooseUs headline={deContent.whyChooseUs.headline} items={deContent.whyChooseUs.items} />
	<FAQ headline={deContent.faq.headline} items={deContent.faq.items} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={deContent.cta.headline} subheadline={deContent.cta.subheadline} button={deContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

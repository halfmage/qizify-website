---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import Testimonials from '../../components/Testimonials.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/learnslice-vs-traditionelle-ausbildung';
---

<BaseLayout title="LearnSlice vs. Traditionelle Ausbildung | Vergleich" description="Vergleichen Sie KI-gest\u00FCtzte Ausbildung mit LearnSlice gegen traditionelle Methoden." lang={lang} currentPath={currentPath}>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={deContent.nav.cta} currentLang={lang} currentPath={currentPath} />

	<section class="pt-32 pb-16 md:pb-24 px-6 md:px-8">
		<div class="max-w-3xl mx-auto text-center">
			<span class="section-label mb-5 block">Vergleich</span>
			<h1 class="text-display-sm md:text-display text-white mb-6">LearnSlice vs. Traditionelle Ausbildungsmethoden</h1>
			<p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">Sehen Sie, wie KI-gest&uuml;tzte Ausbildung im Vergleich zu klassischen Methoden abschneidet.</p>
		</div>
	</section>

	<section class="py-12 md:py-20 px-6 md:px-8">
		<div class="max-w-4xl mx-auto">
			<div class="overflow-x-auto rounded-xl border border-border">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Merkmal</th>
							<th class="text-left text-muted text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3">Traditionell</th>
							<th class="text-left text-xs font-mono uppercase tracking-wider p-4 border-b border-border w-1/3 bg-primary/5"><span class="text-primary">LearnSlice</span></th>
						</tr>
					</thead>
					<tbody class="text-sm">
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Zeit bis Produktivit&auml;t</td><td class="text-muted p-4 border-b border-border">4-6 Monate</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">8 Wochen (65 % schneller)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Ausbilderzeit/Woche</td><td class="text-muted p-4 border-b border-border">8-12 Std. pro Azubi</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">4-6 Std. (50 % weniger)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Abbruchquote</td><td class="text-muted p-4 border-b border-border">30 % Durchschnitt</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">15 % (halbiert)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Verf&uuml;gbarkeit</td><td class="text-muted p-4 border-b border-border">Nur Arbeitszeit</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">24/7 KI-Coaching</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Personalisierung</td><td class="text-muted p-4 border-b border-border">Ein Lehrplan f&uuml;r alle</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Adaptiv pro Lernenden</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">IHK-Pr&uuml;fungsvorbereitung</td><td class="text-muted p-4 border-b border-border">Externe Kurse (&euro;500-&euro;2.000)</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Integriert, KI-generiert</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Unternehmenswissen</td><td class="text-muted p-4 border-b border-border">Manuelle &Uuml;bergabe</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Dokumente hochladen, KI integriert</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Fortschrittskontrolle</td><td class="text-muted p-4 border-b border-border">Manuelle Notizen</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">Echtzeit-Analytics</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">Kosten/Azubi/Jahr</td><td class="text-muted p-4 border-b border-border">&euro;37.000+</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">&euro;15.500 (&euro;21K+ sparen)</td></tr>
						<tr><td class="text-white/70 p-4 border-b border-border font-medium">DSGVO</td><td class="text-muted p-4 border-b border-border">Unterschiedlich</td><td class="text-white p-4 border-b border-border bg-primary/[0.03] font-medium">100 % &mdash; Deutschland</td></tr>
						<tr><td class="text-white/70 p-4 font-medium">Skalierbarkeit</td><td class="text-muted p-4">Lineare Kostensteigerung</td><td class="text-white p-4 bg-primary/[0.03] font-medium">Einmal einrichten, unbegrenzt</td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<section class="py-20 md:py-32 px-6 md:px-8">
		<div class="max-w-container mx-auto">
			<div class="text-center mb-16"><span class="section-label mb-4 block">Ergebnisse</span><h2 class="text-heading md:text-display-sm text-white m-0">Warum Unternehmen wechseln</h2></div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden">
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<div class="text-2xl font-bold text-primary mb-2 tracking-tight">&euro;15K+</div>
					<h3 class="text-base font-semibold text-white mb-2">Ersparnis pro Azubi</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Weniger Ausbilderzeit, keine externen Kurse, schnellere Produktivit&auml;t.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<div class="text-2xl font-bold text-primary mb-2 tracking-tight">24/7</div>
					<h3 class="text-base font-semibold text-white mb-2">KI-Coaching</h3>
					<p class="text-sm text-muted leading-relaxed m-0">Der KI-Coach beantwortet Fragen und stellt &Uuml;bungen bereit &mdash; jederzeit.</p>
				</div>
				<div class="bg-surface p-8 hover:bg-[#151517] transition-colors duration-200">
					<div class="text-2xl font-bold text-primary mb-2 tracking-tight">8 Wo.</div>
					<h3 class="text-base font-semibold text-white mb-2">Bis zur Produktivit&auml;t</h3>
					<p class="text-sm text-muted leading-relaxed m-0">IHK-Lernpfade + Unternehmenswissen = 65 % schneller einsatzbereit.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider headline={deContent.trustedBy.headline} logos={deContent.trustedBy.logos} />
	<Testimonials headline={deContent.testimonials.headline} items={deContent.testimonials.items} currentLang={lang} />
	<LeadCapture currentLang={lang} />
	<CTAFooter headline={deContent.cta.headline} subheadline={deContent.cta.subheadline} button={deContent.cta.button} currentLang={lang} />
	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} />
	<DemoRequestModal currentLang={lang} />
</BaseLayout>

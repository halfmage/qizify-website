---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import LogosSlider from '../../components/LogosSlider.astro';
import Testimonials from '../../components/Testimonials.astro';
import CTAFooter from '../../components/CTAFooter.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/learnslice-vs-traditionelle-ausbildung';
---

<BaseLayout
	title="LearnSlice vs. Traditionelle Ausbildung | Vergleich"
	description="Vergleichen Sie KI-gestützte Ausbildung mit LearnSlice gegen traditionelle Methoden. Sehen Sie, wie KI-Coaching, personalisierte Lernpfade und automatisierte Prüfungen das manuelle Training übertreffen."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={deContent.nav.logo}
		menu={deContent.nav.menu}
		cta={deContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<!-- Hero -->
	<section class="py-16 md:py-24 px-4 md:px-8 bg-dark">
		<div class="max-w-4xl mx-auto text-center">
			<div class="inline-block px-4 py-2 bg-primary/20 border border-primary rounded-full text-white text-sm font-medium uppercase tracking-wider mb-6">
				Vergleich
			</div>
			<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
				LearnSlice vs. Traditionelle<br />Ausbildungsmethoden
			</h1>
			<p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
				Sehen Sie, wie KI-gestützte Ausbildung im Vergleich zu klassischem Präsenzunterricht, manueller Betreuung und externen IHK-Vorbereitungskursen abschneidet.
			</p>
		</div>
	</section>

	<!-- Comparison table -->
	<section class="py-12 md:py-20 px-4 md:px-8 bg-dark">
		<div class="max-w-5xl mx-auto">
			<div class="overflow-x-auto">
				<table class="w-full border-collapse">
					<thead>
						<tr>
							<th class="text-left text-white/60 text-sm font-medium p-4 border-b border-white/10 w-1/3">Merkmal</th>
							<th class="text-left text-white/60 text-sm font-medium p-4 border-b border-white/10 w-1/3">Traditionelle Ausbildung</th>
							<th class="text-left text-sm font-medium p-4 border-b border-primary/50 w-1/3 bg-primary/10 rounded-t-xl">
								<span class="text-primary">LearnSlice</span>
							</th>
						</tr>
					</thead>
					<tbody class="text-sm md:text-base">
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Zeit bis zur Produktivität</td>
							<td class="text-white/50 p-4 border-b border-white/10">4-6 Monate</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">8 Wochen (65 % schneller)</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Ausbilderzeit pro Woche</td>
							<td class="text-white/50 p-4 border-b border-white/10">8-12 Stunden pro Azubi</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">4-6 Stunden (50 % weniger)</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Abbruchquote</td>
							<td class="text-white/50 p-4 border-b border-white/10">30 % Durchschnitt</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">15 % (halbiert)</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Verfügbarkeit</td>
							<td class="text-white/50 p-4 border-b border-white/10">Nur während der Arbeitszeit</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">24/7 KI-Coaching</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Personalisierung</td>
							<td class="text-white/50 p-4 border-b border-white/10">Ein Lehrplan für alle</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">Adaptiv pro Lernenden</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">IHK-Prüfungsvorbereitung</td>
							<td class="text-white/50 p-4 border-b border-white/10">Externe Kurse (€500-€2.000)</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">Integriert, KI-generiert</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Unternehmenswissen</td>
							<td class="text-white/50 p-4 border-b border-white/10">Manuelle Übergabe</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">Dokumente hochladen, KI integriert</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Fortschrittskontrolle</td>
							<td class="text-white/50 p-4 border-b border-white/10">Manuelle Notizen</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">Echtzeit-Analytics-Dashboard</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Prüfungsformate</td>
							<td class="text-white/50 p-4 border-b border-white/10">Papier-Tests</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">Quizzes, Fallstudien, Deep Dives</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">Kosten pro Azubi/Jahr</td>
							<td class="text-white/50 p-4 border-b border-white/10">€37.000+</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">€15.500 (€21K+ sparen)</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 border-b border-white/10 font-medium">DSGVO-Konformität</td>
							<td class="text-white/50 p-4 border-b border-white/10">Unterschiedlich</td>
							<td class="text-white p-4 border-b border-white/10 bg-primary/5 font-semibold">100 % — gehostet in Deutschland</td>
						</tr>
						<tr>
							<td class="text-white/70 p-4 font-medium">Skalierbarkeit</td>
							<td class="text-white/50 p-4">Lineare Kostensteigerung</td>
							<td class="text-white p-4 bg-primary/5 font-semibold rounded-b-xl">Einmal einrichten, unbegrenzt nutzen</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- Why switch -->
	<section class="py-12 md:py-20 px-4 md:px-8 bg-dark">
		<div class="max-w-container mx-auto">
			<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-10 md:mb-14 text-center">
				Warum Unternehmen wechseln
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
				<div class="bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8">
					<div class="text-3xl font-bold text-primary mb-3">€32K+</div>
					<h3 class="text-lg font-bold text-white mb-2">Ersparnis pro Azubi</h3>
					<p class="text-white/70 text-sm leading-relaxed">Weniger Ausbilderzeit, keine externen Kurse, schnellere Produktivität und weniger kostspielige Abbrüche — die Einsparungen summieren sich schnell.</p>
				</div>
				<div class="bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8">
					<div class="text-3xl font-bold text-primary mb-3">24/7</div>
					<h3 class="text-lg font-bold text-white mb-2">KI-Coaching-Verfügbarkeit</h3>
					<p class="text-white/70 text-sm leading-relaxed">Azubis sind nicht auf den Terminplan des Ausbilders angewiesen. Der KI-Coach beantwortet Fragen, erklärt Konzepte und stellt Übungen bereit — jederzeit.</p>
				</div>
				<div class="bg-gray/20 border border-gray/50 rounded-2xl p-6 md:p-8">
					<div class="text-3xl font-bold text-primary mb-3">8 Wo.</div>
					<h3 class="text-lg font-bold text-white mb-2">Bis zur vollen Produktivität</h3>
					<p class="text-white/70 text-sm leading-relaxed">Strukturierte IHK-Lernpfade kombiniert mit Unternehmenswissen machen Azubis 65 % schneller einsatzbereit als traditionelle Methoden.</p>
				</div>
			</div>
		</div>
	</section>

	<LogosSlider
		headline={deContent.trustedBy.headline}
		logos={deContent.trustedBy.logos}
	/>

	<Testimonials
		headline={deContent.testimonials.headline}
		items={deContent.testimonials.items}
		currentLang={lang}
	/>

	<LeadCapture currentLang={lang} />

	<CTAFooter
		headline={deContent.cta.headline}
		subheadline={deContent.cta.subheadline}
		button={deContent.cta.button}
		currentLang={lang}
	/>

	<Footer
		currentLang={lang}
		privacyLabel={deContent.footer.privacyLabel}
		termsLabel={deContent.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>

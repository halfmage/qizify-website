---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import ReadinessCheck from '../../components/ReadinessCheck.astro';
import Footer from '../../components/Footer.astro';
import ConsultationModal from '../../components/ConsultationModal.astro';
import deContent from '../../content/de.json';

const lang = 'de';
const currentPath = '/de/digital-readiness-check';
const ctaLabel = 'Strategiegespräch buchen';
---

<BaseLayout
	title="AZAV- & BFSG-Digital-Readiness-Check für Bildungsträger | LearnSlice"
	description="In 3 Minuten sehen Sie, wo Ihr digitales Angebot bei AZAV, BFSG, KI und Datensouveränität steht. Personalisierter Maßnahmenplan mit passenden Förderwegen, sofort nach dem Check."
	lang={lang}
	currentPath={currentPath}
	breadcrumbTitle="Digital-Readiness-Check"
>
	<Header logo={deContent.nav.logo} menu={deContent.nav.menu} cta={ctaLabel} ctaModalTrigger="project-inquiry" currentLang={lang} currentPath={currentPath} />

	<!-- Hero: kurze Einordnung, dann direkt in den interaktiven Check -->
	<section class="relative overflow-hidden pt-28 md:pt-32 pb-4 md:pb-8 px-6 md:px-8">
		<div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[420px] pointer-events-none glow-aurora opacity-40" aria-hidden="true"></div>
		<div class="max-w-3xl mx-auto relative z-10 text-center">
			<span class="inline-flex items-center gap-1.5 text-xs font-medium text-accent bg-accent/10 border border-accent/30 rounded-full px-3 py-1 mb-5">
				<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.4 6.4L21 9l-5 4.6L17.6 21 12 17.3 6.4 21 8 13.6 3 9l6.6-.6L12 2z"/></svg>
				BMWE KI-Preis 2025 Gewinner
			</span>
			<h1 class="text-display-sm xl:text-display text-balance text-white mb-5">
				Wo steht Ihr digitales Angebot bei <span class="gradient-text-primary">AZAV, BFSG und KI</span>?
			</h1>
			<p class="text-base md:text-lg text-muted leading-relaxed max-w-2xl mx-auto mb-4">
				10 Fragen, 3 Minuten. Sie erhalten einen persönlichen Maßnahmenplan mit konkreten Schritten und passenden Förderwegen.
			</p>
			<div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-muted">
				<span class="inline-flex items-center gap-1.5">
					<svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
					DSGVO-konform
				</span>
				<span class="inline-flex items-center gap-1.5">
					<svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
					Infrastruktur in Deutschland
				</span>
				<span class="inline-flex items-center gap-1.5">
					<svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
					Entwickelt in Europa
				</span>
			</div>
		</div>
	</section>

	<ReadinessCheck />

	<Footer currentLang={lang} privacyLabel={deContent.footer.privacyLabel} termsLabel={deContent.footer.termsLabel} demoHref="#project-inquiry" />

	<ConsultationModal currentLang={lang} />
</BaseLayout>

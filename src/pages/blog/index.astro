---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';
import DemoRequestModal from '../../components/DemoRequestModal.astro';
import enContent from '../../content/en.json';

const lang = 'en';
const currentPath = '/blog';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
	title="Blog | LearnSlice — AI-Powered Apprenticeship Training"
	description="Insights on AI in vocational training, IHK exam preparation, and digital learning for German apprenticeships."
	lang={lang}
	currentPath={currentPath}
>
	<Header
		logo={enContent.nav.logo}
		menu={enContent.nav.menu}
		cta={enContent.nav.cta}
		currentLang={lang}
		currentPath={currentPath}
	/>

	<section class="py-12 md:py-20 px-4 md:px-8 bg-dark">
		<div class="max-w-4xl mx-auto">
			<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">Blog</h1>
			<p class="text-white/70 text-lg mb-10 md:mb-14 max-w-2xl">
				Insights on AI-powered learning, vocational training, and making apprenticeships more effective.
			</p>

			{posts.length === 0 ? (
				<p class="text-white/50 text-lg">No posts yet. Check back soon!</p>
			) : (
				<div class="flex flex-col gap-6">
					{posts.map(post => (
						<BlogCard
							title={post.data.title}
							description={post.data.description}
							publishDate={post.data.publishDate}
							tags={post.data.tags}
							slug={post.slug}
							lang={lang}
						/>
					))}
				</div>
			)}
		</div>
	</section>

	<Footer
		currentLang={lang}
		privacyLabel={enContent.footer.privacyLabel}
		termsLabel={enContent.footer.termsLabel}
	/>

	<DemoRequestModal currentLang={lang} />
</BaseLayout>
